{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Канбан-Планировщик{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <style>
            :root {
                --sidebar-width: 260px;
            }

            /* Базовые стили для тела страницы с открытым сайдбаром */
            body.with-sidebar {
                padding-left: var(--sidebar-width);
                transition: padding-left 0.3s ease;
                position: relative;
            }

            /* Сайдбар */
            .custom-sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                width: var(--sidebar-width);
                z-index: 1040;
                transition: transform 0.3s ease;
                box-shadow: 2px 0 5px rgba(0,0,0,0.1);
            }

            /* Кнопка вызова меню (появляется только когда сайдбар закрыт) */
            .burger-menu-btn {
                position: fixed;
                top: 15px;
                left: 15px;
                z-index: 1030;
                box-shadow: 0 2px 5px rgba(0,0,0,0.2);
                display: none; /* Скрыта по умолчанию, так как сайдбар открыт */
            }

            /* Состояние: Сайдбар СВЕРНУТ */
            body.sidebar-collapsed {
                padding-left: 0 !important;
            }
            body.sidebar-collapsed .custom-sidebar {
                transform: translateX(-100%);
            }
            body.sidebar-collapsed .burger-menu-btn {
                display: block; /* Показываем кнопку, когда меню скрылось */
            }

            /* Адаптивность для мобильных устройств (автоматически скрываем на экранах < 768px) */
            @media (max-width: 767.98px) {
                body.with-sidebar {
                    padding-left: 0 !important;
                }
                .custom-sidebar {
                    transform: translateX(-100%);
                }
                .burger-menu-btn {
                    display: block;
                }
                body.sidebar-mobile-open .custom-sidebar {
                    transform: translateX(0);
                }
            }
        </style>

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="bg-light {% if app.user %}with-sidebar{% endif %}">
        
        {% if app.user %}
            <button class="btn btn-dark burger-menu-btn rounded-pill px-3 fw-bold position-fixed" type="button" onclick="toggleSidebar()">
                ☰ Меню
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="global-sidebar-badge">0</span>
            </button>

            <div class="custom-sidebar bg-dark text-white d-flex flex-column justify-content-between p-3">
                <div>
                    <div class="d-flex justify-content-between align-items-center pb-3 mb-3 border-bottom border-secondary">
                        <h5 class="m-0 text-info text-truncate" style="max-width: 180px;">📋 Планировщик</h5>
                        <button type="button" class="btn btn-sm btn-outline-light border-0" onclick="toggleSidebar()" title="Свернуть меню">
                            ◀
                        </button>
                    </div>
                    
                    <div class="nav flex-column nav-pills">
                        <a href="{{ path('app_dashboard') }}" class="nav-link text-white my-1 py-2 {% if app.request.attributes.get('_route') == 'app_dashboard' or app.request.attributes.get('_route') == 'app_project_view' %}active bg-primary fw-bold{% endif %}">
                            📁 Проекты
                        </a>
                        
                        <a href="{{ path('app_notifications_center') }}" class="nav-link text-white my-1 py-2 d-flex justify-content-between align-items-center {% if app.request.attributes.get('_route') == 'app_notifications_center' %}active bg-primary fw-bold{% endif %}">
                            <span>🔔 Уведомления</span>
                            <span class="badge bg-danger rounded-pill d-none" id="inner-sidebar-badge">0</span>
                        </a>
                        
                        <a href="#" class="nav-link text-white my-1 py-2 opacity-75" onclick="alert('Раздел «Личные сообщения» находится в разработке'); return false;">
                            💬 Личные сообщения
                        </a>
                        
                        <a href="#" class="nav-link text-white my-1 py-2 opacity-75" onclick="alert('Раздел «Профиль» находится в разработке'); return false;">
                            👤 Мой профиль
                        </a>
                    </div>
                </div>

                <div class="border-top border-secondary pt-3">
                    <div class="small text-muted mb-2 text-truncate">Юзер: <strong class="text-light">{{ app.user.email }}</strong></div>
                    <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger w-100">Выйти</a>
                </div>
            </div>

            <script>
                function toggleSidebar() {
                    const body = document.body;
                    if (window.innerWidth >= 768) {
                        body.classList.toggle('sidebar-collapsed');
                        localStorage.setItem('sidebarCollapsed', body.classList.contains('sidebar-collapsed'));
                    } else {
                        body.classList.toggle('sidebar-mobile-open');
                    }
                }

                document.addEventListener('DOMContentLoaded', () => {
                    if (window.innerWidth >= 768 && localStorage.getItem('sidebarCollapsed') === 'true') {
                        document.body.classList.add('sidebar-collapsed');
                    }
                    // Запуск живого счетчика
                    refreshSidebarNotificationCounter();
                });

                function refreshSidebarNotificationCounter() {
                    fetch('/dashboard/notifications/unread-count-api', { method: 'GET' })
                        .then(res => res.json())
                        .then(data => {
                            const count = data.count;
                            const globalBadge = document.getElementById('global-sidebar-badge');
                            const innerBadge = document.getElementById('inner-sidebar-badge');
                            
                            if (count > 0) {
                                if(globalBadge) { globalBadge.innerText = count; globalBadge.classList.remove('d-none'); }
                                if(innerBadge) { innerBadge.innerText = count; innerBadge.classList.remove('d-none'); }
                            } else {
                                if(globalBadge) globalBadge.classList.add('d-none');
                                if(innerBadge) innerBadge.classList.add('d-none');
                            }
                        }).catch(() => {});
                }
            </script>
        {% endif %}

        {# Основное содержимое страницы #}
        {% block body %}{% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>