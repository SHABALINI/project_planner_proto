{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Канбан-Планировщик{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# Подключаем Bootstrap 5 глобально #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <style>
            /* Стили для плавающей бургер-кнопки */
            .burger-menu-btn {
                position: fixed;
                top: 15px;
                left: 15px;
                z-index: 1050; /* Выше обычных элементов */
                box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            }
            /* Смещение контента, чтобы бургер-кнопка не перекрывала заголовки на мобильных */
            body.logged-in-body {
                padding-top: 20px;
            }
        </style>

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="bg-light {% if app.user %}logged-in-body{% endif %}">
        
        {# Бургер-меню рендерится ТОЛЬКО для авторизованных пользователей #}
        {% if app.user %}
            <!-- Кнопка вызова меню -->
            <button class="btn btn-dark burger-menu-btn rounded-pill px-3 fw-bold" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu">
                ☰ Меню
            </button>

            <!-- Левая панель навигации (Бургер-меню) -->
            <div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel" style="width: 280px;">
                <div class="offcanvas-header border-bottom border-secondary">
                    <h5 class="offcanvas-title text-info" id="sidebarMenuLabel">📋 Канбан-Планировщик</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-temporary="offcanvas" data-bs-target="#sidebarMenu" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
                </div>
                <div class="offcanvas-body d-flex flex-column justify-content-between">
                    
                    <!-- Список разделов -->
                    <div class="nav flex-column nav-pills">
                        <!-- Раздел Проекты (Активный роут dashboard) -->
                        <a href="{{ path('app_dashboard') }}" class="nav-link text-white my-1 py-2 {% if app.request.attributes.get('_route') == 'app_dashboard' or app.request.attributes.get('_route') == 'app_project_view' %}active bg-primary fw-bold{% endif %}">
                            📁 Все Проекты
                        </a>
                        
                        <!-- Заглушка: Уведомления -->
                        <a href="#" class="nav-link text-white my-1 py-2 opacity-75" onclick="alert('Раздел «Уведомления» находится в разработке (Заглушка MVP)'); return false;">
                            🔔 Уведомления <span class="badge bg-danger rounded-circle ms-1" style="font-size: 10px;">0</span>
                        </a>
                        
                        <!-- Заглушка: Личные сообщения -->
                        <a href="#" class="nav-link text-white my-1 py-2 opacity-75" onclick="alert('Раздел «Личные сообщения» находится в разработке (Заглушка MVP)'); return false;">
                            💬 Личные сообщения
                        </a>
                        
                        <!-- Заглушка: Профиль -->
                        <a href="#" class="nav-link text-white my-1 py-2 opacity-75" onclick="alert('Раздел «Профиль» находится в разработке (Заглушка MVP)'); return false;">
                            👤 Мой профиль
                        </a>
                    </div>

                    <!-- Нижняя часть меню: Данные юзера и выход -->
                    <div class="border-top border-secondary pt-3">
                        <div class="small text-muted mb-2 text-truncate">Вы вошли как:<br><strong class="text-light">{{ app.user.email }}</strong></div>
                        <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger w-100">Выйти из аккаунта</a>
                    </div>

                </div>
            </div>
        {% endif %}

        {# Основной контент страниц #}
        {% block body %}{% endblock %}

        {# Глобальное подключение JS Bootstrap (необходимо для работы Offcanvas и Модалок) #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>