{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Планировщик проектов{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <link rel="stylesheet" href="{{ asset('vendor/bootstrap/css/bootstrap.min.css') }}">
        
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        <link rel="stylesheet" href="{{ asset('css/components/sidebar.css') }}">
        <link rel="stylesheet" href="{{ asset('css/icons.css') }}">

        {% block stylesheets %}{% endblock %}
        
        {% block javascripts_head %}{% endblock %}
    </head>
    <body class="bg-light {% if app.user %}with-sidebar{% endif %} {% if app.user and app.request.cookies.get('sidebarCollapsed') == 'true' %}sidebar-collapsed{% endif %}">
        
        {% if app.user %}
            <button class="burger-menu-btn" type="button" onclick="toggleSidebar()">
                ☰ Меню
                <span class="badge-notification d-none" id="burger-badge">0</span>
            </button>

            <div class="custom-sidebar">
                <div class="sidebar-brand">
                    <div class="brand-content">
                        <a href="{{ path('app_dashboard') }}" class="brand-logo">
                            <div class="brand-icon"><span style = 'color: #fafafa;'>{{ source('icons/main-logo.svg')|raw }}</span></div>
                            <span class="brand-name">Plan<span>Flow</span></span>
                        </a>
                    </div>
                    <button class="collapse-btn" onclick="toggleSidebar()" title="Свернуть/Развернуть меню">
                        ◀
                    </button>
                </div>

                <nav class="sidebar-nav">
                    <div class="nav-section-title">Основное</div>
                    <a href="{{ path('app_dashboard') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_dashboard' or app.request.attributes.get('_route') == 'app_project_view' %}active{% endif %}" data-tooltip="Проекты">
                        <span>{{ source('icons/project.svg')|raw }}</span>
                        <span class="nav-text">Проекты</span>
                    </a>
                    <a href="{{ path('app_notifications_center') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_notifications_center' %}active{% endif %}" data-tooltip="Уведомления">
                        <span class="nav-icon">🔔</span>
                        <span class="nav-text">Уведомления</span>
                        <span class="nav-badge d-none" id="sidebar-badge">0</span>
                    </a>

                    <div class="nav-section-title">Команда</div>
                    <a href="#" class="nav-link opacity-75" onclick="showComingSoon('Приглашения')" data-tooltip="Приглашения">
                        <span class="nav-icon">📩</span>
                        <span class="nav-text">Приглашения</span>
                        <span class="nav-badge d-none" id="invite-badge">0</span>
                    </a>
                    <a href="#" class="nav-link opacity-75" onclick="showComingSoon('Профиль')" data-tooltip="Профиль">
                        <span class="nav-icon">👤</span>
                        <span class="nav-text">Мой профиль</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="user-info">
                        <div class="user-avatar">{{ app.user.email|first|upper }}</div>
                        <div class="user-details">
                            <div class="user-email">{{ app.user.email }}</div>
                            <div class="user-status"><span class="dot"></span>В сети</div>
                        </div>
                    </div>
                    <a href="{{ path('app_logout') }}" class="logout-btn">
                        🚪 <span class="logout-text">Выйти</span>
                    </a>
                </div>
            </div>

            {# Подключаем общий JS #}
            <script src="{{ asset('js/app.js') }}"></script>

            {# Блок для дополнительных скриптов в body #}
            {% block javascripts_body %}{% endblock %}
        {% endif %}

        {# Основное содержимое страницы #}
        {% block body %}{% endblock %}

        <script src="{{ asset('vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    </body>
</html>