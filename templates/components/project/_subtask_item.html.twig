{# templates/components/project/_subtask_item.html.twig #}
{% set hasSubtaskAccess = (userRole == 'admin' or userRole == 'manager' or (userRole == 'executor' and task.id in allowedTasks)) %}

{% if hasSubtaskAccess %}
<div class="subtask-item" id="subtask-{{ subtask.id }}">
    <div class="d-flex align-items-center gap-2 flex-grow-1">
        <input class="subtask-checkbox" type="checkbox" 
               {% if subtask.status == 'done' %}checked{% endif %} 
               {% if userRole == 'viewer' %}disabled{% endif %} 
               onchange="updateSubtaskStatus({{ subtask.id }}, this.checked)">
        <span class="subtask-label {% if subtask.status == 'done' %}done{% endif %}">{{ subtask.title }}</span>
        
        {% if subtask.description %}
            <span class="text-muted" style="font-size: 10px;" title="Есть описание"><span style = 'color: #6400fa;'>{{ source('icons/describtion.svg')|raw }}</span></span>
        {% endif %}
    </div>
    
    {# Редактирование описания подзадачи #}
    {% if userRole != 'viewer' %}
        <div class="d-flex align-items-center gap-1 flex-grow-1 ms-2" style="max-width: 250px;">
            <input type="text" id="subtaskDescription-{{ subtask.id }}" 
                   class="form-control form-control-sm" 
                   placeholder="Описание..." 
                   value="{{ subtask.description|default('') }}"
                   style="border-radius: 6px; font-size: 12px;"
                   onkeydown="if(event.key==='Enter') updateSubtaskDescription({{ subtask.id }}, this.value)">
            <button class="btn btn-sm btn-outline-secondary" 
                    onclick="updateSubtaskDescription({{ subtask.id }}, document.getElementById('subtaskDescription-{{ subtask.id }}').value)"
                    style="padding: 2px 6px; font-size: 12px;">
                <span style = 'color: #000000;'>{{ source('icons/done.svg')|raw }}</span>
            </button>
        </div>
    {% endif %}
    
    <div class="d-flex align-items-center gap-1">
        {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
            <button class="btn btn-sm text-muted" style="border: none; background: none; font-size: 12px;" onclick="deleteElement('subtask', {{ subtask.id }})">✕</button>
        {% endif %}
    </div>
</div>
{% endif %}