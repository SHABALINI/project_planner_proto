{# templates/components/project/_members_modal.html.twig #}
{% if userRole == 'admin' %}
<div class="modal fade" id="membersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><span style = 'color: #6400fa;'>{{ source('icons/users.svg')|raw }}</span> Управление участниками и добавление в проект</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-5 border-end">
                        <h6>Выберите пользователя:</h6>
                        <div class="mb-2">
                            <input type="text" id="userSearchInput" class="form-control form-control-sm" placeholder="🔍 Введите email для поиска...">
                        </div>
                        <div style="max-height: 250px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;" class="border rounded p-2 bg-light mb-3">
                            <div id="usersModalList"></div>
                        </div>
                    </div>
                    <div class="col-md-7 d-none" id="memberSettingsZone">
                        <h6 id="selectedUserEmail" class="text-primary fw-bold mb-3"></h6>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Правовая роль:</label>
                            <select id="memberRoleSelect" class="form-select" onchange="toggleRoleInterface(this.value)">
                                <option value="viewer">Зритель (без взаимодействия)</option>
                                <option value="executor">Исполнитель (работа с задачами)</option>
                                <option value="manager">Руководитель (управление своими областями)</option>
                                <option value="admin">Админ (полный доступ)</option>
                            </select>
                        </div>
                        <div id="projectAccessTree" class="border p-3 rounded bg-light" style="max-height: 250px; overflow-y: auto;">
                            <label class="fw-bold mb-2 d-block">Зоны ответственности в проекте:</label>
                            {% for area in project.areas %}
                                <div class="mb-2 ms-2 area-node">
                                    <div class="form-check">
                                        <input class="form-check-input area-cb" type="checkbox" value="{{ area.id }}" id="cb-area-{{ area.id }}" onchange="handleAreaCbChange({{ area.id }}, this.checked)">
                                        <label class="form-check-label fw-bold text-success" for="cb-area-{{ area.id }}"><span style = 'color: #6400fa;'>{{ source('icons/area.svg')|raw }}</span> {{ area.title }}</label>
                                    </div>
                                    {% for task in area.tasks %}
                                        <div class="ms-4 task-node">
                                            <div class="form-check">
                                                <input class="form-check-input task-cb" type="checkbox" value="{{ task.id }}" id="cb-task-{{ task.id }}" data-area="{{ area.id }}" onchange="handleTaskCbChange({{ task.id }}, this.checked)">
                                                <label class="form-check-label text-dark" for="cb-task-{{ task.id }}"><span style = 'color: #6400fa;'>{{ source('icons/right.svg')|raw }}</span> {{ task.title }}</label>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endfor %}
                        </div>
                        <button class="btn btn-primary w-100 mt-3 fw-bold" onclick="saveMemberData()">Сохранить настройки участника</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}