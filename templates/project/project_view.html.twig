                showToast('Ошибка при удалении комментария', 'error');
                if (commentItem) {
                    commentItem.style.opacity = '1';
                    commentItem.style.pointerEvents = 'auto';
                }
            });
        }

        // ===== ПОИСК В МОДАЛКЕ =====
        document.getElementById('userSearchInput').addEventListener('input', function(e) {
            const searchText = e.target.value.toLowerCase();
            document.querySelectorAll('.user-search-item').forEach(function(item) {
                const email = item.getAttribute('data-email');
                if (email && email.includes(searchText)) {
                    item.classList.remove('d-none');
                } else {
                    item.classList.add('d-none');
                }
            });
        });

        // ===== ИНИЦИАЛИЗАЦИЯ =====
        document.addEventListener("DOMContentLoaded", function() {
            // Открываем первую область по умолчанию
            const firstAreaBody = document.querySelector('.area-body');
            if (firstAreaBody && !localStorage.getItem(`areaStates_${projectId}`)) {
                firstAreaBody.classList.add('open');
                const firstToggle = document.querySelector('.area-toggle');
                if (firstToggle) firstToggle.classList.remove('collapsed');
            }

            // Восстанавливаем сохраненное состояние
            restoreAreaState();
            
            // Загружаем участников
            refreshMembersPanel();
            
            // Обработка ссылок в комментариях
            const urlPattern = /(\b(https?|ftp|file):\/\/[-A-Z0-9+&@#\/%?=~_|!:,.;]*[-A-Z0-9+&@#\/%=~_|])/ig;
            document.querySelectorAll(".comment-text").forEach(el => {
                let rawText = el.innerHTML;
                let processedText = rawText.replace(urlPattern, '<a href="$1" target="_blank" class="text-primary text-decoration-underline">$1</a>');
                el.innerHTML = processedText;
            });
        });

        // ===== ОТПРАВКА КОММЕНТАРИЯ БЕЗ ПЕРЕЗАГРУЗКИ =====
        document.addEventListener('DOMContentLoaded', function() {
            // Находим все формы для комментариев
            const commentForms = document.querySelectorAll('form[action*="api_comment_create"]');
            console.log('Found comment forms:', commentForms.length); // Для отладки
            
            commentForms.forEach(form => {
                // Удаляем старые обработчики, если есть
                form.removeEventListener('submit', handleCommentSubmit);
                // Добавляем новый
                form.addEventListener('submit', handleCommentSubmit);
            });
        });

        function handleCommentSubmit(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const form = this;
            const formData = new FormData(form);
            const text = formData.get('text');
            const file = formData.get('file');
            
            if (!text.trim() && (!file || file.size === 0)) {
                showToast('Напишите комментарий или прикрепите файл', 'warning');
                return;
            }
            
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.textContent;
            submitBtn.textContent = '⏳';
            submitBtn.disabled = true;
            
            fetch('{{ path("api_comment_create") }}', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(res => {
                if (!res.ok) {
                    return res.text().then(text => {
                        throw new Error('Server error: ' + res.status + ' - ' + text);
                    });
                }
                return res.json();
            })
            .then(data => {
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
                
                if (data.success) {
                    showToast('Комментарий отправлен!', 'success');
                    
                    const taskItem = form.closest('.task-item');
                    if (!taskItem) return;
                    
                    let commentsContainer = taskItem.querySelector('.comments-container');
                    if (!commentsContainer) {
                        const containerDiv = document.createElement('div');
                        containerDiv.className = 'comments-container';
                        const parent = form.parentElement;
                        parent.insertBefore(containerDiv, form);
                        commentsContainer = containerDiv;
                    }
                    
                    const emptyMsg = commentsContainer.querySelector('.text-muted');
                    if (emptyMsg) emptyMsg.remove();
                    
                    const newComment = document.createElement('div');
                    newComment.className = 'comment-item';
                    newComment.id = `comment-${data.id}`;
                    
                    const now = new Date();
                    const timeStr = now.toLocaleString('ru-RU', {
                        day: '2-digit',
                        month: '2-digit',
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    
                    let fileHtml = '';
                    if (data.filePath) {
                        fileHtml = `<a href="${data.filePath}" target="_blank" class="text-purple" style="font-size: 12px;">📎 ${data.fileName}</a>`;
                    }
                    
                    const isAdmin = '{{ userRole }}' === 'admin';
                    const deleteBtn = isAdmin ? 
                        `<button class="btn btn-sm text-danger ms-2" style="border: none; background: none; font-size: 12px;" onclick="deleteComment(${data.id})">✕</button>` : '';
                    
                    // Экранируем текст для безопасности
                    const safeText = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    
                    newComment.innerHTML = `
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="comment-author">👤 ${data.author}</span>
                            <div>
                                <span class="comment-time">${timeStr}</span>
                                ${deleteBtn}
                            </div>
                        </div>
                        <p class="comment-text">${safeText}</p>
                        ${fileHtml}
                    `;
                    commentsContainer.prepend(newComment);
                    
                    // Очищаем форму
                    form.querySelector('input[name="text"]').value = '';
                    const fileInput = form.querySelector('input[type="file"]');
                    if (fileInput) fileInput.value = '';
                } else {
                    showToast('Ошибка: ' + (data.error || 'Неизвестная ошибка'), 'error');
                }
            })
            .catch(err => {
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
                console.error('Error:', err);
                showToast('Ошибка при отправке комментария', 'error');
            });
        }

        // Обновление прогресса области
        function updateAreaProgress(areaCard) {
            const tasks = areaCard.querySelectorAll('.task-item');
            let total = 0;
            let done = 0;
            
            tasks.forEach(task => {
                const status = task.querySelector('.task-status-indicator');
                if (status) {
                    total++;
                    if (status.classList.contains('done')) {
                        done++;
                    } else if (status.classList.contains('progress')) {
                        // Прогресс считается как половинчатый
                        done += 0.5;
                    }
                }
            });
            
            if (total === 0) {
                // Если нет задач, показываем 0%
                const progressBar = areaCard.querySelector('.area-progress-bar');
                const progressText = areaCard.querySelector('.area-progress-text');
                const areaIcon = areaCard.querySelector('.area-icon');
                if (progressBar) progressBar.style.width = '0%';
                if (progressText) progressText.textContent = '0%';
                if (areaIcon) areaIcon.textContent = '📋';
                return;
            }
            
            const percent = Math.round((done / total) * 100);
            const progressBar = areaCard.querySelector('.area-progress-bar');
            const progressText = areaCard.querySelector('.area-progress-text');
            const areaIcon = areaCard.querySelector('.area-icon');
            
            if (progressBar) progressBar.style.width = percent + '%';
            if (progressText) progressText.textContent = percent + '%';
            if (areaIcon) areaIcon.textContent = percent === 100 ? '✅' : '📋';
        }

        // Обновление всех счетчиков
        function updateAllCounters() {
            // Обновляем счетчик участников
            const membersCount = document.querySelectorAll('#membersPanelBody .d-flex').length;
            const badge = document.querySelector('.card-header .badge');
            if (badge) badge.textContent = membersCount;
            
            // Обновляем прогресс проекта
            updateProjectProgress();
        }

        // Обновление прогресса проекта
        function updateProjectProgress() {
            const tasks = document.querySelectorAll('.task-item');
            let total = 0;
            let done = 0;
            
            tasks.forEach(task => {
                const status = task.querySelector('.task-status-indicator');
                if (status) {
                    total++;
                    if (status.classList.contains('done')) {
                        done++;
                    } else if (status.classList.contains('progress')) {
                        done += 0.5;
                    }
                }
            });
            
            if (total === 0) {
                const progressBar = document.querySelector('.progress-bar');
                const progressText = document.querySelector('.fw-bold.text-secondary');
                if (progressBar) progressBar.style.width = '0%';
                if (progressText) progressText.textContent = 'Общая готовность проекта: 0%';
                return;
            }
            
            const percent = Math.round((done / total) * 100);
            const progressBar = document.querySelector('.progress-bar');
            const progressText = document.querySelector('.fw-bold.text-secondary');
            
            if (progressBar) {
                progressBar.style.width = percent + '%';
                progressBar.setAttribute('aria-valuenow', percent);
            }
            if (progressText) {
                progressText.textContent = `Общая готовность проекта: ${percent}%`;
            }
        }
    </script>
{% endblock %}