{# templates/project/project_view.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ project.title }} — Планировщик</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        .task-card { transition: all 0.2s ease; border-left: 5px solid #ffc107; }
        .priority-high { border-left-color: #dc3545 !important; }
        .priority-medium { border-left-color: #ffc107 !important; }
        .priority-low { border-left-color: #0dcaf0 !important; }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width: 1000px;">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="{{ path('app_dashboard') }}" class="btn btn-sm btn-outline-secondary mb-2">← К списку проектов</a>
                <h1 class="m-0 text-primary">📁 {{ project.title }}</h1>
            </div>
            <button class="btn btn-dark btn-sm me-2" 
                data-bs-toggle="modal" 
                data-bs-target="#membersModal" 
                onclick="openMembersModal()">👥 Участники проекта</button>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Выйти</a>
        </div>

        {# Расчет прогресса конкретного проекта #}
        {% set totalProjectPoints = 0 %}
        {% set earnedProjectPoints = 0 %}
        {% for area in project.areas %}
            {% for task in area.tasks %}
                {% set totalProjectPoints = totalProjectPoints + 100 %}
                {% if task.status == 'done' %}
                    {% set earnedProjectPoints = earnedProjectPoints + 100 %}
                {% elseif task.status == 'progress' %}
                    {% set earnedProjectPoints = earnedProjectPoints + 50 %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        {% set projectPercent = totalProjectPoints > 0 ? (earnedProjectPoints / totalProjectPoints * 100)|round : 0 %}

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <small class="fw-bold text-secondary">Общая готовность проекта: {{ projectPercent }}%</small>
                <div class="progress" style="height: 12px;">
                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: {{ projectPercent }}%"></div>
                </div>
            </div>
        </div>

        <div class="bg-white p-3 rounded mb-4 border shadow-sm">
            <h5>Добавить область (Спринт / Категорию)</h5>
            <div class="row g-2">
                <div class="col-md-5">
                    <input type="text" id="areaTitle-{{ project.id }}" class="form-control form-control-sm" placeholder="Название области">
                </div>
                <div class="col-md-5">
                    <input type="text" id="areaDesc-{{ project.id }}" class="form-control form-control-sm" placeholder="Описание области">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success btn-sm w-100 fw-bold" onclick="createArea({{ project.id }})">+ Добавить</button>
                </div>
            </div>
        </div>

        <div class="mt-3">
            {% for area in project.areas %}
                
                {# РАСЧЕТ ПРОЦЕНТОВ ДЛЯ ОБЛАСТИ #}
                {% set totalAreaPoints = area.tasks|length * 100 %}
                {% set earnedAreaPoints = 0 %}
                {% for task in area.tasks %}
                    {% if task.status == 'done' %}
                        {% set earnedAreaPoints = earnedAreaPoints + 100 %}
                    {% elseif task.status == 'progress' %}
                        {% set earnedAreaPoints = earnedAreaPoints + 50 %}
                    {% endif %}
                {% endfor %}
                {% set areaPercent = totalAreaPoints > 0 ? (earnedAreaPoints / totalAreaPoints * 100)|round : 0 %}

                <div class="border p-4 mb-4 bg-white rounded shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="text-success fw-bold m-0">📍 {{ area.title }}</h5>
                        <button class="btn btn-sm btn-outline-danger" style="padding: .2rem .4rem; font-size: .75rem;" 
                                onclick="deleteElement('area', {{ area.id }}, 'Удалить эту область и все её задачи?')">🗑 Удалить область</button>
                    </div>
                    {% if area.description %}<p class="text-muted small mb-2">{{ area.description }}</p>{% endif %}
                    
                    <div class="mb-3">
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: {{ areaPercent }}%"></div>
                        </div>
                        <small class="text-muted" style="font-size: 11px;">Область завершена на {{ areaPercent }}%</small>
                    </div>

                    <div class="bg-light p-2 rounded mb-3 border">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input type="text" id="taskTitle-{{ area.id }}" class="form-control form-control-sm" placeholder="Новая задача...">
                            </div>
                            <div class="col-md-4 d-flex align-items-center">
                                <small class="text-muted me-1 small" style="font-size: 11px; white-space: nowrap;">Срок:</small>
                                <input type="date" id="taskDeadline-{{ area.id }}" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-warning text-dark fw-bold btn-sm w-100" onclick="createTask({{ area.id }})">+ Задача</button>
                            </div>
                        </div>
                    </div>

                    <div id="tasksList-{{ area.id }}">
                        {% for task in area.tasks %}
                            
                            {% set totalSubs = task.subtasks|length %}
                            {% set doneSubs = 0 %}
                            {% for sub in task.subtasks %}
                                {% if sub.status == 'done' %}
                                    {% set doneSubs = doneSubs + 1 %}
                                {% endif %}
                            {% endfor %}
                            {% set taskPercent = totalSubs > 0 ? (doneSubs / totalSubs * 100)|round : 0 %}

                            <div class="card mb-3 task-card priority-{{ task.priority }}" id="task-node-{{ task.id }}">
                                <div class="card-body p-3">
                                    
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="m-0 fw-bold text-dark">{{ task.title }}</h6>
                                        <div class="d-flex align-items-center">
                                            
                                            <span class="badge me-2 text-uppercase 
                                                {% if task.status == 'todo' %}bg-danger
                                                {% elseif task.status == 'progress' %}bg-warning text-dark
                                                {% else %}bg-success{% endif %}">
                                                {% if task.status == 'todo' %}Не выполнено
                                                {% elseif task.status == 'progress' %}В работе
                                                {% else %}Выполнено{% endif %}
                                            </span>

                                            <select class="form-select form-select-sm d-inline-block w-auto me-1" onchange="updateTaskParam({{ task.id }}, 'status', this.value)">
                                                <option value="todo" {% if task.status == 'todo' %}selected{% endif %}>Не выполнено</option>
                                                <option value="progress" {% if task.status == 'progress' %}selected{% endif %}>В работе</option>
                                                <option value="done" {% if task.status == 'done' %}selected{% endif %}>Выполнено</option>
                                            </select>
                                            
                                            <select class="form-select form-select-sm d-inline-block w-auto me-2" onchange="updateTaskParam({{ task.id }}, 'priority', this.value)">
                                                <option value="low" {% if task.priority == 'low' %}selected{% endif %}>Низкий</option>
                                                <option value="medium" {% if task.priority == 'medium' %}selected{% endif %}>Средний</option>
                                                <option value="high" {% if task.priority == 'high' %}selected{% endif %}>Высокий</option>
                                            </select>

                                            <button class="btn btn-link text-danger p-0 border-0" onclick="deleteElement('task', {{ task.id }})">❌</button>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center mb-2 bg-light p-1 rounded border">
                                        <span class="badge bg-secondary me-2">
                                            📅 Дедлайн: {% if task.deadline %}{{ task.deadline|date('d.m.Y') }}{% else %}Не указан{% endif %}
                                        </span>
                                        <div class="d-flex align-items-center ms-auto">
                                            <small class="text-muted me-1" style="font-size: 11px;">Изменить:</small>
                                            <input type="date" class="form-control form-control-sm border-0 bg-transparent p-0" 
                                                   style="width: 130px; font-size: 12px;"
                                                   value="{{ task.deadline ? task.deadline|date('Y-m-d') : '' }}"
                                                   onblur="updateTaskParam({{ task.id }}, 'deadline', this.value)">
                                        </div>
                                    </div>

                                    <div class="mb-2">
                                        <input type="text" class="form-control form-control-sm border-0 bg-light" 
                                               placeholder="Добавить описание..." value="{{ task.description }}" 
                                               onchange="updateTaskParam({{ task.id }}, 'description', this.value)">
                                    </div>

                                    {% if totalSubs > 0 %}
                                    <div class="mb-2" style="font-size: 11px;">
                                        <span class="text-muted">Чек-лист подзадач: {{ taskPercent }}%</span>
                                        <div class="progress" style="height: 4px;">
                                            <div class="progress-bar bg-info" role="progressbar" style="width: {{ taskPercent }}%"></div>
                                        </div>
                                    </div>
                                    {% endif %}

                                    <div class="bg-light p-2 rounded">
                                        <div id="subtasksList-{{ task.id }}">
                                            {% for subtask in task.subtasks %}
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <div class="form-check small m-0">
                                                        <input class="form-check-input" type="checkbox" {% if subtask.status == 'done' %}checked{% endif %}
                                                               onchange="updateSubtaskStatus({{ subtask.id }}, this.checked)">
                                                        <label class="form-check-label {% if subtask.status == 'done' %}text-decoration-line-through text-success fw-bold{% else %}text-danger{% endif %}">
                                                            {{ subtask.title }}
                                                        </label>
                                                    </div>
                                                    <button class="btn btn-link text-muted p-0 m-0 border-0" style="font-size: 11px;" onclick="deleteElement('subtask', {{ subtask.id }})">Удалить</button>
                                                </div>
                                            {% endfor %}
                                        </div>

                                        <div class="input-group input-group-sm mt-2" style="max-width: 350px;">
                                            <input type="text" id="subtaskTitle-{{ task.id }}" class="form-control" placeholder="+ Подзадача">
                                            <button class="btn btn-outline-secondary" onclick="createSubtask({{ task.id }})">+</button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        {% else %}
                            <div class="text-muted small text-center py-2">Нет задач.</div>
                        {% endfor %}
                    </div>

                </div>
            {% else %}
                <div class="text-center py-4 text-muted bg-white rounded border">
                    В этом проекте ещё нет областей. Создайте первую область выше!
                </div>
            {% endfor %}
        </div>
    </div>

    <script>
        function createArea(projectId) {
            const titleInput = document.getElementById(`areaTitle-${projectId}`);
            const descInput = document.getElementById(`areaDesc-${projectId}`);
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/area/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ project_id: projectId, title: titleInput.value, description: descInput.value }) }).then(() => location.reload());
        }

        function createTask(areaId) {
            const titleInput = document.getElementById(`taskTitle-${areaId}`);
            const deadlineInput = document.getElementById(`taskDeadline-${areaId}`);
            if (!titleInput.value.trim()) return;
            
            fetch('/dashboard/task/create', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ 
                    area_id: areaId, 
                    title: titleInput.value,
                    deadline: deadlineInput.value ? deadlineInput.value : null
                }) 
            }).then(() => location.reload());
        }

        function createSubtask(taskId) {
            const titleInput = document.getElementById(`subtaskTitle-${taskId}`);
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/subtask/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, title: titleInput.value }) }).then(() => location.reload());
        }

        function updateTaskParam(taskId, paramName, paramValue) {
            fetch('/dashboard/task/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ task_id: taskId, field: paramName, value: paramValue })
            }).then(() => location.reload());
        }

        function updateSubtaskStatus(subtaskId, isChecked) {
            fetch('/dashboard/subtask/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subtask_id: subtaskId, status: isChecked ? 'done' : 'todo' })
            }).then(() => location.reload());
        }

        function deleteElement(type, id, confirmMessage = null) {
            if (confirmMessage && !confirm(confirmMessage)) return;
            fetch(`/dashboard/delete/${type}/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => { if (data.success) location.reload(); });
        }
    </script>
    <div class="modal fade" id="membersModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">👥 Управление участниками проекта</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-5 border-end">
                            <h6>Выберите пользователя:</h6>
                            <div class="list-group" id="usersModalList" style="max-height: 400px; overflow-y: auto;">
                                </div>
                        </div>
                        
                        <div class="col-md-7 d-none" id="memberSettingsZone">
                            <h6 id="selectedUserEmail" class="text-primary fw-bold mb-3"></h6>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Правовая роль:</label>
                                <select id="memberRoleSelect" class="form-select" onchange="toggleRoleInterface(this.value)">
                                    <option value="viewer">Зритель (просто смотреть за всем)</option>
                                    <option value="executor">Исполнитель (только менять статус своих задач)</option>
                                    <option value="manager">Руководитель (управление своими областями)</option>
                                    <option value="admin">Админ (полный доступ к проекту)</option>
                                </select>
                            </div>

                            <div id="projectAccessTree" class="border p-3 rounded bg-light" style="max-height: 250px; overflow-y: auto;">
                                <label class="fw-bold mb-2 d-block">Зоны ответственности в проекте:</label>
                                
                                {% for area in project.areas %}
                                    <div class="mb-2 ms-2 area-node">
                                        <div class="form-check">
                                            <input class="form-check-input area-cb" type="checkbox" value="{{ area.id }}" id="cb-area-{{ area.id }}" onchange="handleAreaCbChange({{ area.id }}, this.checked)">
                                            <label class="form-check-label fw-bold text-success" for="cb-area-{{ area.id }}">📍 {{ area.title }}</label>
                                        </div>
                                        
                                        {% for task in area.tasks %}
                                            <div class="ms-4 task-node">
                                                <div class="form-check">
                                                    <input class="form-check-input task-cb" type="checkbox" value="{{ task.id }}" id="cb-task-{{ task.id }}" data-area="{{ area.id }}" onchange="handleTaskCbChange({{ task.id }}, this.checked)">
                                                    <label class="form-check-label text-dark" for="cb-task-{{ task.id }}">🔹 {{ task.title }}</label>
                                                </div>
                                                
                                                {% for subtask in task.subtasks %}
                                                    <div class="ms-4">
                                                        <div class="form-check">
                                                            <input class="form-check-input subtask-cb" type="checkbox" value="{{ subtask.id }}" id="cb-subtask-{{ subtask.id }}" data-task="{{ task.id }}">
                                                            <label class="form-check-label text-muted small" for="cb-subtask-{{ subtask.id }}">▪️ {{ subtask.title }}</label>
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>

                            <button class="btn btn-primary w-100 mt-3 fw-bold" onclick="saveMemberData()">Сохранить настройки участника</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script>
        let currentSelectedUserId = null;
        let membersModalObj = null;

        function openMembersModal() {
            // Сбрасываем панель настроек
            document.getElementById('memberSettingsZone').classList.add('d-none');
            
            // Загружаем данные с бэкенда
            fetch('/dashboard/project/{{ project.id }}/members')
                .then(res => res.json())
                .then(users => {
                    const list = document.getElementById('usersModalList');
                    list.innerHTML = '';
                    
                    users.forEach(user => {
                        const btn = document.createElement('button');
                        btn.className = `list-group-item list-group-item-action d-flex justify-content-between align-items-center ${user.isMember ? 'list-group-item-success' : ''}`;
                        btn.innerHTML = `<span>${user.email}</span> ${user.isMember ? '<span class="badge bg-success">'+user.role+'</span>' : ''}`;
                        btn.onclick = () => selectUserForEdition(user);
                        list.appendChild(btn);
                    });
                });
        }

        function selectUserForEdition(user) {
            currentSelectedUserId = user.id;
            document.getElementById('selectedUserEmail').innerText = `Настройка: ${user.email}`;
            document.getElementById('memberRoleSelect').value = user.role;
            document.getElementById('memberSettingsZone').classList.remove('d-none');

            // Снимаем все галочки по умолчанию
            document.querySelectorAll('.form-check-input').forEach(cb => cb.checked = false);

            // Проставляем сохраненные галочки
            user.areas.forEach(id => { const c = document.getElementById(`cb-area-${id}`); if(c) c.checked = true; });
            user.tasks.forEach(id => { const c = document.getElementById(`cb-task-${id}`); if(c) c.checked = true; });
            user.subtasks.forEach(id => { const c = document.getElementById(`cb-subtask-${id}`); if(c) c.checked = true; });

            toggleRoleInterface(user.role);
        }

        function toggleRoleInterface(role) {
            const tree = document.getElementById('projectAccessTree');
            
            if (role === 'admin' || role === 'viewer') {
                tree.classList.add('d-none'); // Админу и зрителю галочки не нужны
            } else {
                tree.classList.remove('d-none');
                
                // Руководителям — прячем задачи и подзадачи (им можно выбирать только области)
                document.querySelectorAll('.task-node').forEach(node => {
                    node.style.display = (role === 'manager') ? 'none' : 'block';
                });
            }
        }

        // ИНТЕРФЕЙСНЫЙ АЛГОРИТМ: область -> проставились задачи
        function handleAreaCbChange(areaId, isChecked) {
            const role = document.getElementById('memberRoleSelect').value;
            if (role !== 'executor') return; // Применяем каскад только для исполнителей

            document.querySelectorAll(`.task-cb[data-area="${areaId}"]`).forEach(taskCb => {
                taskCb.checked = isChecked;
                handleTaskCbChange(taskCb.value, isChecked);
            });
        }

        // ИНТЕРФЕЙСНЫЙ АЛГОРИТМ: задача -> подзадачи
        function handleTaskCbChange(taskId, isChecked) {
            const role = document.getElementById('memberRoleSelect').value;
            if (role !== 'executor') return;

            document.querySelectorAll(`.subtask-cb[data-task="${taskId}"]`).forEach(subtaskCb => {
                subtaskCb.checked = isChecked;
            });
        }

        function saveMemberData() {
            const role = document.getElementById('memberRoleSelect').value;
            
            // Предупреждение для роли Админ по ТЗ
            if (role === 'admin' && !confirm('Внимание! Вы собираетесь назначить пользователя Администратором. Он получит полный доступ ко всему проекту. Продолжить?')) {
                return;
            }

            const areas = Array.from(document.querySelectorAll('.area-cb:checked')).map(cb => parseInt(cb.value));
            const tasks = Array.from(document.querySelectorAll('.task-cb:checked')).map(cb => parseInt(cb.value));
            const subtasks = Array.from(document.querySelectorAll('.subtask-cb:checked')).map(cb => parseInt(cb.value));

            fetch('/dashboard/project/{{ project.id }}/member/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    user_id: currentSelectedUserId,
                    role: role,
                    areas: areas,
                    tasks: tasks,
                    subtasks: subtasks
                })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    alert('Права участника успешно обновлены!');
                    openMembersModal(); // Обновляем список
                }
            });
        }
    </script>
</body>
</html>