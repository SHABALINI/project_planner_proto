{# templates/project/project_view.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} — Планировщик{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/project/project.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/progress.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/area.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/task.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/subtask.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/comment.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project/members.css') }}">
{% endblock %}

{% block javascripts_body %}
    {{ parent() }}
    
    <script>
        window.projectId = {{ project.id }};
        window.userRole = '{{ userRole }}';
        window.currentUserId = {{ app.user.id }};
        window.currentUserEmail = '{{ app.user.email }}';
        window.projectOwnerId = {{ project.owner.id }};
        
        {# Статистика #}
        {% set totalTasks = 0 %}
        {% set totalDone = 0 %}
        {% set totalProgress = 0 %}
        {% for area in project.areas %}
            {% set totalTasks = totalTasks + area.tasks|length %}
            {% set totalDone = totalDone + area.tasks|filter(t => t.status == 'done')|length %}
            {% set totalProgress = totalProgress + area.tasks|filter(t => t.status == 'progress')|length %}
        {% endfor %}
        
        window.projectStats = {
            totalTasks: {{ totalTasks }},
            totalDone: {{ totalDone }},
            totalProgress: {{ totalProgress }}
        };
        
        window.areaStats = {};
        {% for area in project.areas %}
            window.areaStats[{{ area.id }}] = {
                totalTasks: {{ area.tasks|length }},
                totalDone: {{ area.tasks|filter(t => t.status == 'done')|length }},
                totalProgress: {{ area.tasks|filter(t => t.status == 'progress')|length }}
            };
        {% endfor %}
    </script>
    
    <script src="{{ asset('js/components/utils.js') }}"></script>
    <script src="{{ asset('js/project/progress.js') }}"></script>
    <script src="{{ asset('js/project/tasks.js') }}"></script>
    <script src="{{ asset('js/project/comments.js') }}"></script>
    <script src="{{ asset('js/project/members.js') }}"></script>
    <script src="{{ asset('js/project/main.js') }}"></script>
{% endblock %}

{% block body %}
    <div id="toastContainer"></div>
    
    <div class="container-fluid mt-3">
        <div class="row">
            <div class="col-md-9">
                {{ include('components/project/_header.html.twig') }}
                {{ include('components/project/_progress.html.twig') }}

                {% if userRole == 'admin' %}
                    <div class="bg-white p-3 rounded mb-4 border shadow-sm" style="border: 2px dashed var(--primary-purple-border); border-radius: 16px;">
                        <h5>Добавить область (Спринт / Категорию)</h5>
                        <div class="row g-2">
                            <div class="col-md-5">
                                <input type="text" id="areaTitle-{{ project.id }}" class="form-control form-control-sm" placeholder="Название области" style="border-radius: 10px;">
                            </div>
                            <div class="col-md-5">
                                <input type="text" id="areaDesc-{{ project.id }}" class="form-control form-control-sm" placeholder="Описание области" style="border-radius: 10px;">
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-purple btn-sm w-100" onclick="createArea({{ project.id }})">+ Добавить</button>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <div class="mt-3">
                    {% for area in project.areas %}
                        {% set hasAreaAccess = (userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) or (userRole == 'executor' and area.id in allowedAreas) or (userRole == 'viewer')) %}
                        {% if hasAreaAccess %}
                            {{ include('components/project/_area_card.html.twig', { area: area }) }}
                        {% endif %}
                    {% endfor %}
                </div>
            </div>

            {{ include('components/project/_members_panel.html.twig') }}
        </div>
    </div>

    {{ include('components/project/_members_modal.html.twig') }}
{% endblock %}