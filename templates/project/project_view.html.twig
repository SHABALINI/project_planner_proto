{# templates/project/project_view.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} — Планировщик{% endblock %}

{% block stylesheets %}
    <style>
        .task-card { transition: all 0.2s ease; border-left: 5px solid #ffc107; }
        .priority-high { border-left-color: #dc3545 !important; }
        .priority-medium { border-left-color: #ffc107 !important; }
        .priority-low { border-left-color: #0dcaf0 !important; }
    </style>
{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 1000px;">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="{{ path('app_dashboard') }}" class="btn btn-sm btn-outline-secondary mb-2">← К списку проектов</a>
                <h1 class="m-0 text-primary">📁 {{ project.title }} 
                    <span class="badge bg-info text-dark fs-6 font-monospace">Роль: {{ userRole|upper }}</span>
                </h1>
            </div>
            <div>
                {% if userRole == 'admin' %}
                    <button class="btn btn-dark btn-sm me-2" data-bs-toggle="modal" data-bs-target="#membersModal" onclick="openMembersModal()">👥 Участники проекта</button>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">Выйти</a>
            </div>
        </div>

        {# ... Весь остальной существующий код шаблона project_view (progress-bar, области, задачи, комментарии, модалка) остается абсолютно без изменений ... #}
        
        {% set totalProjectPoints = 0 %}{% set earnedProjectPoints = 0 %}
        {% for area in project.areas %}
            {% for task in area.tasks %}
                {% set totalProjectPoints = totalProjectPoints + 100 %}
                {% if task.status == 'done' %}{% set earnedProjectPoints = earnedProjectPoints + 100 %}
                {% elseif task.status == 'progress' %}{% set earnedProjectPoints = earnedProjectPoints + 50 %}{% endif %}
            {% endfor %}
        {% endfor %}
        {% set projectPercent = totalProjectPoints > 0 ? (earnedProjectPoints / totalProjectPoints * 100)|round : 0 %}

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <small class="fw-bold text-secondary">Общая готовность проекта: {{ projectPercent }}%</small>
                <div class="progress" style="height: 12px;">
                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: {{ projectPercent }}%"></div>
                </div>
            </div>
        </div>

        {% if userRole == 'admin' %}
        <div class="bg-white p-3 rounded mb-4 border shadow-sm">
            <h5>Добавить область (Спринт / Категорию)</h5>
            <div class="row g-2">
                <div class="col-md-5"><input type="text" id="areaTitle-{{ project.id }}" class="form-control form-control-sm" placeholder="Название области"></div>
                <div class="col-md-5"><input type="text" id="areaDesc-{{ project.id }}" class="form-control form-control-sm" placeholder="Описание области"></div>
                <div class="col-md-2"><button class="btn btn-success btn-sm w-100 fw-bold" onclick="createArea({{ project.id }})">+ Добавить</button></div>
            </div>
        </div>
        {% endif %}

        <div class="mt-3">
            {% for area in project.areas %}
                {% set hasAreaAccess = (userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) or userRole == 'executor' or userRole == 'viewer') %}
                
                {% if hasAreaAccess %}
                {% set totalAreaPoints = area.tasks|length * 100 %}{% set earnedAreaPoints = 0 %}
                {% for task in area.tasks %}{% if task.status == 'done' %}{% set earnedAreaPoints = earnedAreaPoints + 100 %}{% elseif task.status == 'progress' %}{% set earnedAreaPoints = earnedAreaPoints + 50 %}{% endif %}{% endfor %}
                {% set areaPercent = totalAreaPoints > 0 ? (earnedAreaPoints / totalAreaPoints * 100)|round : 0 %}

                <div class="border p-4 mb-4 bg-white rounded shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="text-success fw-bold m-0">📍 {{ area.title }}</h5>
                        {% if userRole == 'admin' %}
                            <button class="btn btn-sm btn-outline-danger" style="padding: .2rem .4rem; font-size: .75rem;" onclick="deleteElement('area', {{ area.id }}, 'Удалить эту область и все её задачи?')">🗑 Удалить область</button>
                        {% endif %}
                    </div>
                    {% if area.description %}<p class="text-muted small mb-2">{{ area.description }}</p>{% endif %}
                    
                    <div class="mb-3">
                        <div class="progress" style="height: 6px;"><div class="progress-bar bg-success" role="progressbar" style="width: {{ areaPercent }}%"></div></div>
                        <small class="text-muted" style="font-size: 11px;">Область завершена на {{ areaPercent }}%</small>
                    </div>

                    {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
                    <div class="bg-light p-2 rounded mb-3 border">
                        <div class="row g-2">
                            <div class="col-md-6"><input type="text" id="taskTitle-{{ area.id }}" class="form-control form-control-sm" placeholder="Новая задача..."></div>
                            <div class="col-md-4 d-flex align-items-center">
                                <small class="text-muted me-1 small" style="font-size: 11px; white-space: nowrap;">Срок:</small>
                                <input type="date" id="taskDeadline-{{ area.id }}" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-2"><button class="btn btn-warning text-dark fw-bold btn-sm w-100" onclick="createTask({{ area.id }})">+ Задача</button></div>
                        </div>
                    </div>
                    {% endif %}

                    <div id="tasksList-{{ area.id }}">
                        {% for task in area.tasks %}
                            {% set hasTaskAccess = (userRole == 'admin' or userRole == 'manager' or (userRole == 'executor' and task.id in allowedTasks)) %}
                            
                            {% if hasTaskAccess %}
                            {% set totalSubs = task.subtasks|length %}{% set doneSubs = 0 %}{% for sub in task.subtasks %}{% if sub.status == 'done' %}{% set doneSubs = doneSubs + 1 %}{% endif %}{% endfor %}
                            {% set taskPercent = totalSubs > 0 ? (doneSubs / totalSubs * 100)|round : 0 %}

                            <div class="card mb-3 task-card priority-{{ task.priority }}" id="task-node-{{ task.id }}">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="m-0 fw-bold text-dark">{{ task.title }}</h6>
                                        <div class="d-flex align-items-center">
                                            <span class="badge me-2 text-uppercase {% if task.status == 'todo' %}bg-danger{% elseif task.status == 'progress' %}bg-warning text-dark{% else %}bg-success{% endif %}">
                                                {% if task.status == 'todo' %}Не выполнено{% elseif task.status == 'progress' %}В работе{% else %}Выполнено{% endif %}
                                            </span>

                                            {% if userRole != 'viewer' %}
                                                <select class="form-select form-select-sm d-inline-block w-auto me-1" onchange="updateTaskParam({{ task.id }}, 'status', this.value)">
                                                    <option value="todo" {% if task.status == 'todo' %}selected{% endif %}>Не выполнено</option>
                                                    <option value="progress" {% if task.status == 'progress' %}selected{% endif %}>В работе</option>
                                                    <option value="done" {% if task.status == 'done' %}selected{% endif %}>Выполнено</option>
                                                </select>
                                            {% endif %}
                                            
                                            {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
                                                <select class="form-select form-select-sm d-inline-block w-auto me-2" onchange="updateTaskParam({{ task.id }}, 'priority', this.value)">
                                                    <option value="low" {% if task.priority == 'low' %}selected{% endif %}>Низкий</option>
                                                    <option value="medium" {% if task.priority == 'medium' %}selected{% endif %}>Средний</option>
                                                    <option value="high" {% if task.priority == 'high' %}selected{% endif %}>Высокий</option>
                                                </select>
                                                <button class="btn btn-link text-danger p-0 border-0" onclick="deleteElement('task', {{ task.id }})">❌</button>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center mb-2 bg-light p-1 rounded border">
                                        <span class="badge bg-secondary me-2">📅 Дедлайн: {{ task.deadline ? task.deadline|date('d.m.Y') : 'Не указан' }}</span>
                                        {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
                                            <div class="d-flex align-items-center ms-auto">
                                                <small class="text-muted me-1" style="font-size: 11px;">Изменить:</small>
                                                <input type="date" class="form-control form-control-sm border-0 bg-transparent p-0" style="width: 130px; font-size: 12px;" value="{{ task.deadline ? task.deadline|date('Y-m-d') : '' }}" onblur="updateTaskParam({{ task.id }}, 'deadline', this.value)">
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="mb-2">
                                        <input type="text" class="form-control form-control-sm border-0 bg-light" placeholder="Описание задачи..." value="{{ task.description }}" 
                                               {% if userRole == 'executor' or userRole == 'viewer' %}disabled{% endif %} onchange="updateTaskParam({{ task.id }}, 'description', this.value)">
                                    </div>

                                    {% if totalSubs > 0 %}
                                    <div class="mb-2" style="font-size: 11px;">
                                        <span class="text-muted">Чек-лист: {{ taskPercent }}%</span>
                                        <div class="progress" style="height: 4px;"><div class="progress-bar bg-info" role="progressbar" style="width: {{ taskPercent }}%"></div></div>
                                    </div>
                                    {% endif %}

                                    <div class="bg-light p-2 rounded">
                                        <div id="subtasksList-{{ task.id }}">
                                            {% for subtask in task.subtasks %}
                                                {% set hasSubtaskAccess = (userRole == 'admin' or userRole == 'manager' or (userRole == 'executor' and subtask.id in allowedSubtasks)) %}
                                                {% if hasSubtaskAccess %}
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <div class="form-check small m-0">
                                                        <input class="form-check-input" type="checkbox" {% if subtask.status == 'done' %}checked{% endif %} {% if userRole == 'viewer' %}disabled{% endif %} onchange="updateSubtaskStatus({{ subtask.id }}, this.checked)">
                                                        <label class="form-check-label {% if subtask.status == 'done' %}text-decoration-line-through text-success fw-bold{% else %}text-danger{% endif %}">{{ subtask.title }}</label>
                                                    </div>
                                                    {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
                                                        <button class="btn btn-link text-muted p-0 m-0 border-0" style="font-size: 11px;" onclick="deleteElement('subtask', {{ subtask.id }})">Удалить</button>
                                                    {% endif %}
                                                </div>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                        
                                        <div class="mt-3 pt-3 border-top">
                                        <h6 class="text-secondary small fw-bold mb-2">💬 Комментарии:</h6>
                                        
                                        <div class="comments-container mb-2" style="max-height: 200px; overflow-y: auto;">
                                            {% for comment in task.comments|default([]) %}
                                                <div class="bg-white border rounded p-2 mb-2 shadow-none position-relative" style="font-size: 13px;">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <span class="fw-bold text-primary">
                                                            👤 {{ comment.author.email|default(comment.author.userIdentifier) }}
                                                        </span>
                                                        <span class="text-muted" style="font-size: 11px;">
                                                            {{ comment.createdAt|date('d.m.Y H:i') }}
                                                            {% set canDeleteComment = (comment.author == currentUser or userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas)) %}
                                                            {% if canDeleteComment %}
                                                                <button class="btn btn-link text-danger p-0 ms-2 text-decoration-none" style="font-size: 11px;" onclick="deleteComment({{ comment.id }})">🗑</button>
                                                            {% endif %}
                                                        </span>
                                                    </div>
                                                    <p class="m-0 text-dark comment-text-raw">{{ comment.text }}</p>
                                                    {% if comment.filePath %}
                                                        <div class="mt-1 bg-light p-1 rounded border d-inline-block">
                                                            <a href="{{ comment.filePath }}" target="_blank" class="text-success text-decoration-none fw-bold" style="font-size: 11px;">
                                                                📎 Скачать: {{ comment.fileName }}
                                                            </a>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            {% else %}
                                                <div class="text-muted small p-1">Комментариев пока нет.</div>
                                            {% endfor %}
                                        </div>

                                        <form action="{{ path('api_comment_create') }}" method="POST" enctype="multipart/form-data" class="mt-2">
                                            <input type="hidden" name="task_id" value="{{ task.id }}">
                                            <div class="input-group input-group-sm mb-1">
                                                <input type="text" name="text" class="form-control" placeholder="Напишите комментарий или вставьте ссылку...">
                                                <button type="submit" class="btn btn-primary fw-bold">Отправить</button>
                                            </div>
                                            <div class="d-flex align-items-center bg-light p-1 rounded border" style="max-width: 300px;">
                                                <small class="text-muted me-2" style="font-size: 11px; white-space: nowrap;">📎 Файл:</small>
                                                <input type="file" name="file" class="form-control form-control-sm border-0 bg-transparent" style="font-size: 11px;">
                                            </div>
                                        </form>
                                    </div>

                                        {% if userRole == 'admin' or (userRole == 'manager' and area.id in allowedAreas) %}
                                        <div class="input-group input-group-sm mt-2" style="max-width: 350px;">
                                            <input type="text" id="subtaskTitle-{{ task.id }}" class="form-control" placeholder="+ Подзадача">
                                            <button class="btn btn-outline-secondary" onclick="createSubtask({{ task.id }})">+</button>
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                        {% else %}
                            <div class="text-muted small text-center py-2">Нет задач.</div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {% if userRole == 'admin' %}
    <div class="modal fade" id="membersModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">👥 Управление участниками проекта</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-5 border-end">
                            <h6>Выберите пользователя:</h6>
                            <div class="mb-2">
                                <input type="text" id="userSearchInput" class="form-control form-control-sm" placeholder="🔍 Введите email для поиска...">
                            </div>
                            <div style="max-height: 250px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;" class="border rounded p-2 bg-light mb-3">
                                <div id="usersModalList"></div>
                            </div>
                        </div>
                        <div class="col-md-7 d-none" id="memberSettingsZone">
                            <h6 id="selectedUserEmail" class="text-primary fw-bold mb-3"></h6>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Правовая роль:</label>
                                <select id="memberRoleSelect" class="form-select" onchange="toggleRoleInterface(this.value)">
                                    <option value="viewer">Зритель (просто смотреть за всем)</option>
                                    <option value="executor">Исполнитель (только менять статус своих задач)</option>
                                    <option value="manager">Руководитель (управление своими областями)</option>
                                    <option value="admin">Админ (полный доступ к проекту)</option>
                                </select>
                            </div>
                            <div id="projectAccessTree" class="border p-3 rounded bg-light" style="max-height: 250px; overflow-y: auto;">
                                <label class="fw-bold mb-2 d-block">Зоны ответственности в проекте:</label>
                                {% for area in project.areas %}
                                    <div class="mb-2 ms-2 area-node">
                                        <div class="form-check">
                                            <input class="form-check-input area-cb" type="checkbox" value="{{ area.id }}" id="cb-area-{{ area.id }}" onchange="handleAreaCbChange({{ area.id }}, this.checked)">
                                            <label class="form-check-label fw-bold text-success" for="cb-area-{{ area.id }}">📍 {{ area.title }}</label>
                                        </div>
                                        {% for task in area.tasks %}
                                            <div class="ms-4 task-node">
                                                <div class="form-check">
                                                    <input class="form-check-input task-cb" type="checkbox" value="{{ task.id }}" id="cb-task-{{ task.id }}" data-area="{{ area.id }}" onchange="handleTaskCbChange({{ task.id }}, this.checked)">
                                                    <label class="form-check-label text-dark" for="cb-task-{{ task.id }}">🔹 {{ task.title }}</label>
                                                </div>
                                                {% for subtask in task.subtasks %}
                                                    <div class="ms-4">
                                                        <div class="form-check">
                                                            <input class="form-check-input subtask-cb" type="checkbox" value="{{ subtask.id }}" id="cb-subtask-{{ subtask.id }}" data-task="{{ task.id }}">
                                                            <label class="form-check-label text-muted small" for="cb-subtask-{{ subtask.id }}">▪️ {{ subtask.title }}</label>
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>
                            <button class="btn btn-primary w-100 mt-3 fw-bold" onclick="saveMemberData()">Сохранить настройки участника</button>
                        </div> </div> </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% if userRole == 'admin' or userRole == 'owner' %}
    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">👥 Управление участниками</h5>
        </div>
        <div class="card-body">
            <div class="list-group">
                {# Владелец #}
                <div class="list-group-item d-flex justify-content-between align-items-center bg-light">
                    <div>
                        <strong>👑 {{ project.owner.email }}</strong>
                        <span class="badge bg-warning ms-2">Владелец</span>
                    </div>
                    <span class="text-muted">Нельзя удалить</span>
                </div>
                
                {# Участники #}
                {% for member in project_members %}
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>👤 {{ member.user.email }}</strong>
                            <span class="badge bg-info ms-2">{{ member.role|upper }}</span>
                            {% if member.role == 'manager' %}
                                <span class="badge bg-secondary">Областей: {{ member.areas|length }}</span>
                            {% endif %}
                            {% if member.role == 'executor' %}
                                <span class="badge bg-secondary">Задач: {{ member.tasks|length }}</span>
                            {% endif %}
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="removeMember({{ member.user.id }})">
                            🗑 Удалить
                        </button>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    <script>
        const projectId = {{ project.id }};

        let currentSelectedUserId = null;
        function openMembersModal() {
            document.getElementById('memberSettingsZone').classList.add('d-none');
            const searchInput = document.getElementById('userSearchInput');
            if (searchInput) searchInput.value = '';

            fetch('{{ path("api_project_members", {"id": project.id}) }}')
                .then(res => res.json())
                .then(users => {
                    const list = document.getElementById('usersModalList');
                    list.innerHTML = '';
                    const currentEmail = '{{ currentUser.email }}';
                    const filteredUsers = users.filter(u => u.email !== currentEmail);

                    if (filteredUsers.length === 0) {
                        list.innerHTML = '<div class="text-muted small p-2">Нет других зарегистрированных пользователей.</div>';
                        return;
                    }
                    filteredUsers.forEach(user => {
                        const btn = document.createElement('div');
                        btn.className = `user-search-item p-2 mb-1 rounded border d-flex justify-content-between align-items-center` + 
                                        ` ${user.isMember ? 'bg-success-subtle text-success-emphasis border-success-subtle' : 'bg-white border-secondary-subtle'}`;
                        btn.setAttribute('data-email', user.email.toLowerCase());
                        btn.style.fontSize = '13px';
                        btn.style.cursor = 'pointer';
                        btn.innerHTML = `<span>👤 ${user.email}</span> ${user.isMember ? '<span class="badge bg-success">'+user.role+'</span>' : ''}`;
                        btn.onclick = () => {
                            document.querySelectorAll('.user-search-item').forEach(b => {
                                b.style.borderColor = '';
                                b.style.boxShadow = '';
                            });
                            btn.style.borderColor = '#0d6efd';
                            btn.style.boxShadow = '0 0 0 0.25rem rgba(13, 110, 253, 0.25)';
                            selectUserForEdition(user);
                        };
                        list.appendChild(btn);
                    });
                });
        }

        function selectUserForEdition(user) {
            currentSelectedUserId = user.id;
            document.getElementById('selectedUserEmail').innerText = `Настройка: ${user.email}`;
            document.getElementById('memberRoleSelect').value = user.role;
            document.getElementById('memberSettingsZone').classList.remove('d-none');

            document.querySelectorAll('.form-check-input').forEach(cb => cb.checked = false);
            user.areas.forEach(id => { const c = document.getElementById(`cb-area-${id}`); if(c) c.checked = true; });
            user.tasks.forEach(id => { const c = document.getElementById(`cb-task-${id}`); if(c) c.checked = true; });
            user.subtasks.forEach(id => { const c = document.getElementById(`cb-subtask-${id}`); if(c) c.checked = true; });

            toggleRoleInterface(user.role);
        }

        function toggleRoleInterface(role) {
            const tree = document.getElementById('projectAccessTree');
            if (role === 'admin' || role === 'viewer') {
                tree.classList.add('d-none');
            } else {
                tree.classList.remove('d-none');
                document.querySelectorAll('.task-node').forEach(node => {
                    node.style.display = (role === 'manager') ? 'none' : 'block';
                });
            }
        }

        function handleAreaCbChange(areaId, isChecked) {
            if (document.getElementById('memberRoleSelect').value !== 'executor') return;
            document.querySelectorAll(`.task-cb[data-area="${areaId}"]`).forEach(taskCb => {
                taskCb.checked = isChecked;
                handleTaskCbChange(taskCb.value, isChecked);
            });
        }

        function handleTaskCbChange(taskId, isChecked) {
            if (document.getElementById('memberRoleSelect').value !== 'executor') return;
            document.querySelectorAll(`.subtask-cb[data-task="${taskId}"]`).forEach(subtaskCb => {
                subtaskCb.checked = isChecked;
            });
        }

        function saveMemberData() {
            const role = document.getElementById('memberRoleSelect').value;
            if (role === 'admin' && !confirm('Внимание! Вы собираетесь назначить Администратора. Продолжить?')) return;

            const areas = Array.from(document.querySelectorAll('.area-cb:checked')).map(cb => parseInt(cb.value));
            const tasks = Array.from(document.querySelectorAll('.task-cb:checked')).map(cb => parseInt(cb.value));
            const subtasks = Array.from(document.querySelectorAll('.subtask-cb:checked')).map(cb => parseInt(cb.value));

            fetch('{{ path("api_project_member_save", {"id": project.id}) }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ user_id: currentSelectedUserId, role: role, areas: areas, tasks: tasks, subtasks: subtasks })
            }).then(res => res.json()).then(data => {
                if(data.success) { alert('Права успешно обновлены!'); openMembersModal(); }
            });
        }

        function removeMember(userId) {
            if (!confirm('Удалить участника?')) return;
            
            fetch(`/dashboard/project/${projectId}/member/remove/${userId}`, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Участник удален!');
                    location.reload();
                } else {
                    alert('Ошибка: ' + data.error);
                }
            });
        }

        function createArea(projectId) {
            const titleInput = document.getElementById(`areaTitle-${projectId}`);
            const descInput = document.getElementById(`areaDesc-${projectId}`);
            if (!titleInput.value.trim()) return;
            fetch('{{ path("api_area_create") }}', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ project_id: projectId, title: titleInput.value, description: descInput.value }) }).then(() => location.reload());
        }

        function createTask(areaId) {
            const titleInput = document.getElementById(`taskTitle-${areaId}`);
            const deadlineInput = document.getElementById(`taskDeadline-${areaId}`);
            if (!titleInput.value.trim()) return;
            fetch('{{ path("app_task_create") }}', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ area_id: areaId, title: titleInput.value, deadline: deadlineInput.value || null }) }).then(() => location.reload());
        }

        function createSubtask(taskId) {
            const titleInput = document.getElementById(`subtaskTitle-${taskId}`);
            if (!titleInput.value.trim()) return;
            fetch('{{ path("api_subtask_create") }}', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, title: titleInput.value }) }).then(() => location.reload());
        }

        function updateTaskParam(taskId, paramName, paramValue) {
            fetch('{{ path("app_task_update") }}', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, field: paramName, value: paramValue }) }).then(() => location.reload());
        }

        function updateSubtaskStatus(subtaskId, isChecked) {
            fetch('{{ path("api_subtask_update") }}', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ subtask_id: subtaskId, status: isChecked ? 'done' : 'todo' }) }).then(() => location.reload());
        }

        function deleteElement(type, id, confirmMessage = null) {
            if (confirmMessage && !confirm(confirmMessage)) return;
            fetch(`/dashboard/delete/${type}/${id}`, { method: 'POST' }).then(res => res.json()).then(data => { if (data.success) location.reload(); });
        }

        function deleteComment(commentId) {
            if (!confirm('Вы действительно хотите удалить этот комментарий?')) return;
            fetch(`/dashboard/comment/delete/${commentId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) location.reload();
                    else alert('Ошибка: ' + (data.error || 'Не удалось удалить комментарий'));
                }).catch(err => console.error(err));
        }

        document.getElementById('userSearchInput').addEventListener('input', function(e) {
            const searchText = e.target.value.toLowerCase();
            document.querySelectorAll('.user-search-item').forEach(function(item) {
                const email = item.getAttribute('data-email');
                if (email && email.includes(searchText)) item.classList.remove('d-none');
                else item.classList.add('d-none');
            });
        });

        document.addEventListener("DOMContentLoaded", function() {
            const urlPattern = /(\b(https?|ftp|file):\/\/[-A-Z0-9+&@#\/%?=~_|!:,.;]*[-A-Z0-9+&@#\/%=~_|])/ig;
            document.querySelectorAll(".comment-text-raw").forEach(el => {
                let rawText = el.innerHTML;
                let processedText = rawText.replace(urlPattern, '<a href="$1" target="_blank" class="text-primary text-decoration-underline">$1</a>');
                el.innerHTML = processedText;
            });
        });
    </script>
{% endblock %}