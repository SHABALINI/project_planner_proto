{# templates/project/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Панель проектов — Планировщик{% endblock %}

{% block body %}
    {# Класс ps-md-5 добавляет отступ слева, чтобы кнопка «Меню» смотрелась органично #}
    <div class="container mt-5 ps-md-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="ms-4">📋 Мои Проекты</h1>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Выйти</a>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Создать новый проект</h5>
                <div class="input-group">
                    <input type="text" id="projectTitle" class="form-control" placeholder="Название проекта">
                    <button class="btn btn-primary" onclick="createProject()">Создать проект</button>
                </div>
            </div>
        </div>

        <div id="projectsList" class="row row-cols-1 row-cols-md-2 g-4">
            {% for project in projects %}
                {% set totalProjectPoints = 0 %}
                {% set earnedProjectPoints = 0 %}
                {% for area in project.areas %}
                    {% for task in area.tasks %}
                        {% set totalProjectPoints = totalProjectPoints + 100 %}
                        {% if task.status == 'done' %}
                            {% set earnedProjectPoints = earnedProjectPoints + 100 %}
                        {% elseif task.status == 'progress' %}
                            {% set earnedProjectPoints = earnedProjectPoints + 50 %}
                        {% endif %}
                    {% endfor %}
                {% endfor %}
                {% set projectPercent = totalProjectPoints > 0 ? (earnedProjectPoints / totalProjectPoints * 100)|round : 0 %}

                <div class="col" id="project-card-{{ project.id }}">
                    <div class="card h-100 shadow-sm border-primary">
                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title text-primary fw-bold">{{ project.title }}</h4>
                            
                            <div class="mt-2 mb-4">
                                <small class="fw-bold text-secondary">Готовность: {{ projectPercent }}%</small>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-primary" role="progressbar" style="width: {{ projectPercent }}%"></div>
                                </div>
                            </div>
                            
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_project_view', {'id': project.id}) }}" class="btn btn-primary btn-sm px-4 fw-bold">Открыть проект 🚀</a>
                                
                                {% if project.owner == app.user %}
                                    <button class="btn btn-outline-danger btn-sm" onclick="deleteElement('project', {{ project.id }}, 'Удалить весь проект со всеми областями и задачами?')">🗑</button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 w-100 text-center py-5 text-muted">
                    <h3>У вас пока нет созданных проектов.</h3>
                    <p>Введите название выше и нажмите «Создать проект», чтобы начать.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <script>
        function createProject() {
            const titleInput = document.getElementById('projectTitle');
            const titleValue = titleInput.value.trim();
            if (!titleValue) return;
            
            fetch('{{ path("api_project_create") }}', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ title: titleValue }) 
            })
            .then(res => {
                if (!res.ok) {
                    alert('Сервер вернул код ошибки: ' + res.status);
                    throw new Error('Код ответа сервера: ' + res.status);
                }
                return res.json();
            })
            .then(data => {
                if (data.success) {
                    titleInput.value = '';
                    location.reload();
                } else {
                    alert('Ошибка логики: ' + (data.error || 'Неизвестно'));
                }
            })
            .catch(err => {
                console.error('Критическая ошибка fetch:', err);
                alert('Не удалось связаться с сервером. Проверьте консоль (F12)');
            });
        }

        function deleteElement(type, id, confirmMessage = null) {
            if (confirmMessage && !confirm(confirmMessage)) return;
            fetch(`/dashboard/delete/${type}/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => { if (data.success) location.reload(); });
        }
    </script>
{% endblock %}