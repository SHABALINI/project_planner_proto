<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Планировщик проектов</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .task-card { transition: all 0.2s ease; border-left: 5px solid #ffc107; }
        .priority-high { border-left-color: #dc3545 !important; }
        .priority-medium { border-left-color: #ffc107 !important; }
        .priority-low { border-left-color: #0dcaf0 !important; }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width: 1000px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>📋 Мои Проекты</h1>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Выйти</a>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Создать новый проект</h5>
                <div class="input-group">
                    <input type="text" id="projectTitle" class="form-control" placeholder="Название проекта">
                    <button class="btn btn-primary" onclick="createProject()">Создать проект</button>
                </div>
            </div>
        </div>

        <div id="projectsList">
            {% for project in projects %}
                
                {#Проценты для проекта#}
                {% set totalProjectPoints = 0 %}
                {% set earnedProjectPoints = 0 %}
                {% for area in project.areas %}
                    {% for task in area.tasks %}
                        {% set totalProjectPoints = totalProjectPoints + 100 %}
                        {% if task.status == 'done' %}
                            {% set earnedProjectPoints = earnedProjectPoints + 100 %}
                        {% elseif task.status == 'progress' %}
                            {% set earnedProjectPoints = earnedProjectPoints + 50 %}{# 50% за "В работе" #}
                        {% endif %}
                    {% endfor %}
                {% endfor %}
                {% set projectPercent = totalProjectPoints > 0 ? (earnedProjectPoints / totalProjectPoints * 100)|round : 0 %}

                <div class="card mb-5 border-primary shadow" id="project-card-{{ project.id }}">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h3 class="m-0">{{ project.title }}</h3>
                        <button class="btn btn-danger btn-sm" onclick="deleteElement('project', {{ project.id }}, 'Удалить весь проект со всеми областями и задачами?')">🗑 Удалить проект</button>
                    </div>
                    <div class="card-body">
                        
                        <div class="mb-4">
                            <small class="fw-bold text-secondary">Готовность проекта: {{ projectPercent }}%</small>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: {{ projectPercent }}%"></div>
                            </div>
                        </div>
                        
                        <div class="bg-light p-3 rounded mb-4 border">
                            <h6>Добавить область (Спринт / Категорию)</h6>
                            <div class="row g-2">
                                <div class="col-md-5">
                                    <input type="text" id="areaTitle-{{ project.id }}" class="form-control form-control-sm" placeholder="Название области">
                                </div>
                                <div class="col-md-5">
                                    <input type="text" id="areaDesc-{{ project.id }}" class="form-control form-control-sm" placeholder="Описание">
                                </div>
                                <div 
                                    <button class="btn btn-success btn-sm w-100" onclick="createArea({{ project.id }})">Добавить</button>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            {% for area in project.areas %}
                                
                                {# ИСПРАВЛЕНО: РАСЧЕТ ПРОЦЕНТОВ ДЛЯ ОБЛАСТИ #}
                                {% set totalAreaPoints = area.tasks|length * 100 %}
                                {% set earnedAreaPoints = 0 %}
                                {% for task in area.tasks %}
                                    {% if task.status == 'done' %}
                                        {% set earnedAreaPoints = earnedAreaPoints + 100 %}
                                    {% elseif task.status == 'progress' %}
                                        {% set earnedAreaPoints = earnedAreaPoints + 50 %}
                                    {% endif %}
                                {% endfor %}
                                {% set areaPercent = totalAreaPoints > 0 ? (earnedAreaPoints / totalAreaPoints * 100)|round : 0 %}

                                <div class="border p-4 mb-4 bg-white rounded shadow-sm">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="text-success fw-bold m-0">📍 {{ area.title }}</h5>
                                        <button class="btn btn-outline-danger btn-sm" style="padding: .2rem .4rem; font-size: .75rem;" 
                                                onclick="deleteElement('area', {{ area.id }}, 'Удалить эту область и все её задачи?')">🗑 Удалить область</button>
                                    </div>
                                    {% if area.description %}<p class="text-muted small mb-2">{{ area.description }}</p>{% endif %}
                                    
                                    <div class="mb-3">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width: {{ areaPercent }}%"></div>
                                        </div>
                                        <small class="text-muted" style="font-size: 11px;">Область завершена на {{ areaPercent }}%</small>
                                    </div>

                                    <div class="input-group input-group-sm mb-3">
                                        <input type="text" id="taskTitle-{{ area.id }}" class="form-control" placeholder="Новая задача...">
                                        <button class="btn btn-warning text-dark fw-bold" onclick="createTask({{ area.id }})">+ Задача</button>
                                    </div>

                                    <div id="tasksList-{{ area.id }}">
                                        {% for task in area.tasks %}
                                            
                                            {# ИСПРАВЛЕНО: РАСЧЕТ ПРОЦЕНТОВ ДЛЯ ЗАДАЧИ ПО ПОДЗАДАЧАМ #}
                                            {% set totalSubs = task.subtasks|length %}
                                            {% set doneSubs = 0 %}
                                            {% for sub in task.subtasks %}
                                                {% if sub.status == 'done' %}
                                                    {% set doneSubs = doneSubs + 1 %}
                                                {% endif %}
                                            {% endfor %}
                                            {% set taskPercent = totalSubs > 0 ? (doneSubs / totalSubs * 100)|round : 0 %}

                                            <div class="card mb-3 task-card priority-{{ task.priority }}" id="task-node-{{ task.id }}">
                                                <div class="card-body p-3">
                                                    
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <h6 class="m-0 fw-bold text-dark">{{ task.title }}</h6>
                                                        <div class="d-flex align-items-center">
                                                            
                                                            <span class="badge me-2 text-uppercase 
                                                                {% if task.status == 'todo' %}bg-danger
                                                                {% elseif task.status == 'progress' %}bg-warning text-dark
                                                                {% else %}bg-success{% endif %}">
                                                                {% if task.status == 'todo' %}Не выполнено
                                                                {% elseif task.status == 'progress' %}В работе
                                                                {% else %}Выполнено{% endif %}
                                                            </span>

                                                            <select class="form-select form-select-sm d-inline-block w-auto me-1" onchange="updateTaskParam({{ task.id }}, 'status', this.value)">
                                                                <option value="todo" {% if task.status == 'todo' %}selected{% endif %}>Не выполнено (Красный)</option>
                                                                <option value="progress" {% if task.status == 'progress' %}selected{% endif %}>В работе (Желтый)</option>
                                                                <option value="done" {% if task.status == 'done' %}selected{% endif %}>Выполнено (Зеленый)</option>
                                                            </select>
                                                            
                                                            <select class="form-select form-select-sm d-inline-block w-auto me-2" onchange="updateTaskParam({{ task.id }}, 'priority', this.value)">
                                                                <option value="low" {% if task.priority == 'low' %}selected{% endif %}>Низкий</option>
                                                                <option value="medium" {% if task.priority == 'medium' %}selected{% endif %}>Средний</option>
                                                                <option value="high" {% if task.priority == 'high' %}selected{% endif %}>Высокий</option>
                                                            </select>

                                                            <button class="btn btn-link text-danger p-0 border-0" onclick="deleteElement('task', {{ task.id }})">❌</button>
                                                        </div>
                                                    </div>

                                                    <div class="mb-2">
                                                        <input type="text" class="form-control form-control-sm border-0 bg-light" 
                                                               placeholder="Добавить описание..." value="{{ task.description }}" 
                                                               onchange="updateTaskParam({{ task.id }}, 'description', this.value)">
                                                    </div>

                                                    {% if totalSubs > 0 %}
                                                    <div class="mb-2" style="font-size: 11px;">
                                                        <span class="text-muted">Чек-лист подзадач: {{ taskPercent }}%</span>
                                                        <div class="progress" style="height: 4px;">
                                                            <div class="progress-bar bg-info" role="progressbar" style="width: {{ taskPercent }}%"></div>
                                                        </div>
                                                    </div>
                                                    {% endif %}

                                                    <div class="bg-light p-2 rounded">
                                                        <div id="subtasksList-{{ task.id }}">
                                                            {% for subtask in task.subtasks %}
                                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                                    <div class="form-check small m-0">
                                                                        <input class="form-check-input" type="checkbox" {% if subtask.status == 'done' %}checked{% endif %}
                                                                               onchange="updateSubtaskStatus({{ subtask.id }}, this.checked)">
                                                                        
                                                                        <label class="form-check-label {% if subtask.status == 'done' %}text-decoration-line-through text-success fw-bold{% else %}text-danger{% endif %}">
                                                                            {{ subtask.title }}
                                                                        </label>
                                                                    </div>
                                                                    <button class="btn btn-link text-muted p-0 m-0 border-0" style="font-size: 11px;" onclick="deleteElement('subtask', {{ subtask.id }})">Удалить</button>
                                                                </div>
                                                            {% endfor %}
                                                        </div>

                                                        <div class="input-group input-group-sm mt-2" style="max-width: 350px;">
                                                            <input type="text" id="subtaskTitle-{{ task.id }}" class="form-control" placeholder="+ Подзадача">
                                                            <button class="btn btn-outline-secondary" onclick="createSubtask({{ task.id }})">+</button>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="text-muted small text-center py-2">Нет задач.</div>
                                        {% endfor %}
                                    </div>

                                </div>
                            {% endfor %}
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <script>
        function createProject() {
            const titleInput = document.getElementById('projectTitle');
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/project/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: titleInput.value }) }).then(() => location.reload());
        }

        function createArea(projectId) {
            const titleInput = document.getElementById(`areaTitle-${projectId}`);
            const descInput = document.getElementById(`areaDesc-${projectId}`);
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/area/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ project_id: projectId, title: titleInput.value, description: descInput.value }) }).then(() => location.reload());
        }

        function createTask(areaId) {
            const titleInput = document.getElementById(`taskTitle-${areaId}`);
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/task/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ area_id: areaId, title: titleInput.value }) }).then(() => location.reload());
        }

        function createSubtask(taskId) {
            const titleInput = document.getElementById(`subtaskTitle-${taskId}`);
            if (!titleInput.value.trim()) return;
            fetch('/dashboard/subtask/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, title: titleInput.value }) }).then(() => location.reload());
        }

        function updateTaskParam(taskId, paramName, paramValue) {
            fetch('/dashboard/task/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ task_id: taskId, field: paramName, value: paramValue })
            }).then(() => location.reload());
        }

        function updateSubtaskStatus(subtaskId, isChecked) {
            fetch('/dashboard/subtask/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subtask_id: subtaskId, status: isChecked ? 'done' : 'todo' })
            }).then(() => location.reload());
        }

        function deleteElement(type, id, confirmMessage = null) {
            if (confirmMessage && !confirm(confirmMessage)) return;

            fetch(`/dashboard/delete/${type}/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => { if (data.success) location.reload(); });
        }
    </script>
</body>
</html>