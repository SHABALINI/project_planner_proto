{% extends 'base.html.twig' %}

{% block title %}Панель проектов — Планировщик{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/project/dashboard.css') }}">
{% endblock %}

{% block body %}
    <div class="container mt-4" style="max-width: 1000px;">
        {# Шапка дашборда #}
        <div class="dashboard-header">
            <div>
                <h1>📋 Мои проекты</h1>
                <p>Управляйте своими проектами, отслеживайте прогресс и достигайте целей</p>
            </div>
            <div class="dashboard-stats">
                <div class="stat-item">
                    📁 <strong>{{ projects|length }}</strong> проектов
                </div>
                <div class="stat-item">
                    ⛳ <strong>{{ projects|reduce((carry, p) => carry + p.areas|length, 0) }}</strong> областей
                </div>
                <div class="stat-item">
                    📋 <strong>{{ projects|reduce((carry, p) => carry + p.areas|reduce((c, a) => c + a.tasks|length, 0), 0) }}</strong> задач
                </div>
            </div>
        </div>

        <div class="create-card">
            <h5>✨ Создать новый проект</h5>
            <div class="input-group">
                <input type="text" id="projectTitle" class="form-control" placeholder="Введите название проекта..." onkeydown="if(event.key==='Enter') createProject()">
                <button class="btn" onclick="createProject()">Создать проект</button>
            </div>
        </div>

        {% set pinnedProjects = projects|filter(p => app.user.isProjectPinned(p.id)) %}
        {% if pinnedProjects|length > 0 %}
            <div class="section-title">
                📌 Закрепленные
                <span class="badge-count">{{ pinnedProjects|length }}</span>
            </div>
            <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
                {% for project in pinnedProjects %}
                    {{ _self.renderProjectCard(project, app.user) }}
                {% endfor %}
            </div>
        {% endif %}

        {% set unpinnedProjects = projects|filter(p => not app.user.isProjectPinned(p.id)) %}
        {% if unpinnedProjects|length > 0 %}
            <div class="section-title">
                📂 Все проекты
                <span class="badge-count">{{ unpinnedProjects|length }}</span>
            </div>
            <div class="row row-cols-1 row-cols-md-2 g-4">
                {% for project in unpinnedProjects %}
                    {{ _self.renderProjectCard(project, app.user) }}
                {% endfor %}
            </div>
        {% endif %}

        {# Если нет проектов #}
        {% if projects|length == 0 %}
            <div class="empty-state">
                <span class="empty-icon">🚀</span>
                <h3>Начните с создания проекта</h3>
                <p>Создайте свой первый проект, чтобы начать организовывать задачи и управлять командой</p>
            </div>
        {% endif %}
    </div>

    {# Макрос для отображения карточки проекта #}
    {% macro renderProjectCard(project, currentUser) %}
        {% set totalTasks = 0 %}
        {% set doneTasks = 0 %}
        {% set totalAreas = project.areas|length %}
        
        {% for area in project.areas %}
            {% for task in area.tasks %}
                {% set totalTasks = totalTasks + 1 %}
                {% if task.status == 'done' %}
                    {% set doneTasks = doneTasks + 1 %}
                {% elseif task.status == 'progress' %}
                    {% set doneTasks = doneTasks + 0.5 %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        
        {% set projectPercent = totalTasks > 0 ? (doneTasks / totalTasks * 100)|round : 0 %}
        {% set isOwner = project.owner.id == currentUser.id %}
        {% set isPinned = currentUser.isProjectPinned(project.id) %}

        <div class="col" id="project-card-{{ project.id }}">
            <div class="project-card">
                <div class="project-card-header">
                    <h5 class="project-card-title">
                        <a href="{{ path('app_project_view', {'id': project.id}) }}">{{ project.title }}</a>
                    </h5>
                    <div class="project-card-actions">
                        <button class="pin-btn {% if isPinned %}pinned{% else %}unpinned{% endif %}" 
                                onclick="togglePin({{ project.id }})" 
                                title="{% if isPinned %}Открепить{% else %}Закрепить{% endif %}">
                            📌
                        </button>
                        {% if isOwner %}
                            <button class="btn-icon danger" onclick="deleteElement('project', {{ project.id }}, 'Удалить проект «{{ project.title }}» со всеми данными?')" title="Удалить проект">
                                🗑
                            </button>
                        {% endif %}
                    </div>
                </div>

                <div class="project-progress">
                    <div class="progress-label">
                        <span>Прогресс</span>
                        <span>{{ projectPercent }}%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ projectPercent }}%"></div>
                    </div>
                </div>

                <div class="project-stats">
                    <span class="stat">
                        <span class="icon">⛳</span>
                        <strong>{{ totalAreas }}</strong> областей
                    </span>
                    <span class="stat">
                        <span class="icon">📋</span>
                        <strong>{{ totalTasks }}</strong> задач
                    </span>
                    <span class="stat">
                        <span class="icon">✅</span>
                        <strong>{{ (doneTasks)|round }}</strong> выполнено
                    </span>
                    <span class="stat ms-auto">
                        <a href="{{ path('app_project_view', {'id': project.id}) }}" class="btn btn-sm" style="background: var(--primary-purple); color: white; border-radius: 8px; padding: 4px 16px; font-size: 13px; text-decoration: none; transition: all 0.2s ease;">
                            Открыть →
                        </a>
                    </span>
                </div>
            </div>
        </div>
    {% endmacro %}

    <script>
        function createProject() {
            const titleInput = document.getElementById('projectTitle');
            const titleValue = titleInput.value.trim();
            if (!titleValue) {
                titleInput.focus();
                titleInput.style.borderColor = '#ef4444';
                setTimeout(() => titleInput.style.borderColor = '', 2000);
                return;
            }
            
            const btn = document.querySelector('.create-card .input-group button');
            const originalText = btn.textContent;
            btn.textContent = '⏳ Создание...';
            btn.disabled = true;
            
            fetch('{{ path("api_project_create") }}', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ title: titleValue }) 
            })
            .then(res => {
                if (!res.ok) throw new Error('Server error: ' + res.status);
                return res.json();
            })
            .then(data => {
                btn.textContent = originalText;
                btn.disabled = false;
                
                if (data.success) {
                    titleInput.value = '';
                    location.reload();
                } else {
                    alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                }
            })
            .catch(err => {
                btn.textContent = originalText;
                btn.disabled = false;
                console.error('Error:', err);
                alert('Не удалось создать проект. Проверьте консоль.');
            });
        }

        function deleteElement(type, id, confirmMessage = null) {
            if (confirmMessage && !confirm(confirmMessage)) return;
            
            const card = document.getElementById(`project-card-${id}`);
            if (card) {
                card.style.transition = 'all 0.3s ease';
                card.style.opacity = '0.5';
                card.style.transform = 'scale(0.95)';
            }
            
            fetch(`/dashboard/delete/${type}/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => { 
                if (data.success) {
                    location.reload();
                } else {
                    alert('Ошибка: ' + (data.error || 'Не удалось удалить'));
                    if (card) {
                        card.style.opacity = '1';
                        card.style.transform = 'scale(1)';
                    }
                }
            })
            .catch(err => {
                console.error('Error:', err);
                alert('Ошибка при удалении');
                if (card) {
                    card.style.opacity = '1';
                    card.style.transform = 'scale(1)';
                }
            });
        }

        function togglePin(projectId) {
            const btn = document.querySelector(`#project-card-${projectId} .pin-btn`);
            if (btn) {
                btn.textContent = '⏳';
                btn.disabled = true;
            }
            
            fetch(`/dashboard/project/${projectId}/toggle-pin`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Ошибка: ' + (data.error || 'Не удалось закрепить проект'));
                    if (btn) {
                        btn.textContent = '📌';
                        btn.disabled = false;
                    }
                }
            })
            .catch(err => {
                console.error('Error:', err);
                alert('Ошибка при закреплении проекта');
                if (btn) {
                    btn.textContent = '📌';
                    btn.disabled = false;
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.project-card').forEach((card, i) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(16px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.4s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, 50 * i);
            });
        });
    </script>
{% endblock %}