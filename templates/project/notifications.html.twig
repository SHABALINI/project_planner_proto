{# templates/project/notifications.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Центр уведомлений — Планировщик{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/project/notifications.css') }}">
{% endblock %}

{% block body %}
<div class="notifications-container">
    {# Шапка #}
    <div class="notifications-header">
        <div class="notifications-header-left">
            <h1>🔔 Уведомления</h1>
            <span class="unread-badge" id="unreadCount">
                {% if totalUnreadCount > 0 %}
                    {{ totalUnreadCount }} непрочитанных
                {% else %}
                    Все прочитано ✨
                {% endif %}
            </span>
        </div>
        <div class="notifications-header-actions">
            <button class="btn-mark-all-read" id="markAllReadBtn" onclick="markAllAsRead()" {% if totalUnreadCount == 0 %}disabled{% endif %}>
                ✅ Отметить все прочитанными
            </button>
        </div>
    </div>

    {# Фильтры - выпадающий список #}
    <div class="notifications-filters">
        <div class="filter-select-wrapper">
            <select class="filter-select" id="filterSelect" onchange="filterNotificationsBySelect(this.value)">
                <option value="all">📬 Все уведомления ({{ allNotifications|length }})</option>
                <option value="unread">🔵 Непрочитанные {% if totalUnreadCount > 0 %}({{ totalUnreadCount }}){% endif %}</option>
                <option value="read">✅ Прочитанные</option>
                {% if groupedProjects|length > 0 %}
                    <option disabled>──────────</option>
                    <option disabled>📁 По проектам:</option>
                    {% for pId, data in groupedProjects %}
                        <option value="project-{{ pId }}">
                            {{ data.project.title }} 
                            {% if data.unreadCount > 0 %}🔴 {{ data.unreadCount }}{% endif %}
                        </option>
                    {% endfor %}
                {% endif %}
            </select>
        </div>
        
        {# Быстрые фильтры для часто используемых проектов (макс 3) #}
        {% if groupedProjects|length <= 3 %}
            <div class="quick-filters">
                {% for pId, data in groupedProjects %}
                    <button class="filter-btn quick-filter" data-filter="project-{{ pId }}" onclick="filterNotifications('project-{{ pId }}', this)">
                        {{ data.project.title|length > 12 ? data.project.title|slice(0, 12) ~ '…' : data.project.title }}
                        {% if data.unreadCount > 0 %}
                            <span class="count-unread">{{ data.unreadCount }}</span>
                        {% endif %}
                    </button>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Список уведомлений #}
    <div class="notifications-list" id="notificationsList">
        {% if allNotifications|length > 0 %}
            {% for n in allNotifications %}
                {{ _self.renderNotification(n) }}
            {% endfor %}
        {% else %}
            <div class="empty-notifications">
                <span class="empty-icon">🎉</span>
                <h3>У вас нет уведомлений</h3>
                <p>Когда появятся новые уведомления, они будут отображаться здесь</p>
            </div>
        {% endif %}
    </div>
</div>

{# Макрос для рендеринга уведомления #}
{% macro renderNotification(n) %}
    {% set iconMap = {
        'project': '📁',
        'task': '📋',
        'comment': '💬',
        'member': '👤',
        'system': '⚙️'
    } %}
    {% set iconType = n.type|default('system') %}
    {% set icon = iconMap[iconType]|default('📌') %}

    <div class="notification-item {% if not n.isRead %}unread{% endif %}" 
         id="notification-{{ n.id }}" 
         data-id="{{ n.id }}" 
         data-read="{{ n.isRead ? 'true' : 'false' }}"
         data-project="{{ n.project.id }}">
        
        <div class="notification-icon {{ iconType }}">
            {{ icon }}
        </div>

        <div class="notification-content">
            <div class="notification-title">
                <span class="project-name">{{ n.title }}</span>
            </div>
            <div class="notification-message">{{ n.message }}</div>
            <div class="notification-meta">
                <span class="time">🕐 {{ n.createdAt|date('d.m.Y H:i') }}</span>
                <span class="project-tag">📁 {{ n.project.title }}</span>
                {% if not n.isRead %}
                    <span class="badge" style="background: var(--primary-purple); color: white; font-size: 10px; padding: 1px 8px; border-radius: 12px;">Новое</span>
                {% endif %}
            </div>
        </div>

        <div class="notification-actions">
            {% if not n.isRead %}
                <button class="btn-action mark-read" onclick="markAsRead({{ n.id }})">✔ Прочитать</button>
            {% endif %}
            {% if n.targetUrl %}
                <button class="btn-action go-to" onclick="goToNotification({{ n.id }}, '{{ n.targetUrl }}')">Перейти →</button>
            {% endif %}
        </div>
    </div>
{% endmacro %}

<script>
    //  ФИЛЬТРАЦИЯ ЧЕРЕЗ ВЫПАДАЮЩИЙ СПИСОК 
    function filterNotificationsBySelect(value) {
        // Обновляем активные кнопки
        document.querySelectorAll('.quick-filters .filter-btn').forEach(b => {
            b.classList.remove('active');
        });
        
        filterNotifications(value, null);
    }

    //  ФИЛЬТРАЦИЯ 
    function filterNotifications(filter, btn) {
        // Обновляем активную кнопку (если есть)
        if (btn) {
            document.querySelectorAll('.quick-filters .filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            // Обновляем выпадающий список
            const select = document.getElementById('filterSelect');
            if (select) select.value = filter;
        }

        const items = document.querySelectorAll('.notification-item');
        let visibleCount = 0;

        items.forEach(item => {
            let show = false;
            
            if (filter === 'all') {
                show = true;
            } else if (filter === 'unread') {
                show = item.dataset.read === 'false';
            } else if (filter === 'read') {
                show = item.dataset.read === 'true';
            } else if (filter.startsWith('project-')) {
                const projectId = filter.replace('project-', '');
                show = item.dataset.project == projectId;
            }
            
            if (show) {
                item.style.display = '';
                visibleCount++;
            } else {
                item.style.display = 'none';
            }
        });

        // Показываем сообщение если ничего не найдено
        const list = document.getElementById('notificationsList');
        let emptyMsg = list.querySelector('.empty-notifications');
        
        if (visibleCount === 0) {
            if (!emptyMsg) {
                const msg = document.createElement('div');
                msg.className = 'empty-notifications';
                msg.innerHTML = `
                    <span class="empty-icon">🔍</span>
                    <h3>Нет уведомлений</h3>
                    <p>По выбранному фильтру ничего не найдено</p>
                `;
                list.appendChild(msg);
            }
        } else {
            if (emptyMsg) emptyMsg.remove();
        }
    }

    //  ОТМЕТКА ОДНОГО УВЕДОМЛЕНИЯ КАК ПРОЧИТАННОГО 
    function markAsRead(id) {
        fetch(`/dashboard/notifications/read/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const item = document.getElementById(`notification-${id}`);
                    if (item) {
                        item.classList.remove('unread');
                        item.dataset.read = 'true';
                        const badge = item.querySelector('.badge');
                        if (badge) badge.remove();
                        const markBtn = item.querySelector('.mark-read');
                        if (markBtn) markBtn.remove();
                    }
                    updateCounters();
                }
            })
            .catch(err => console.error('Error:', err));
    }

    //  ОТМЕТКА ВСЕХ КАК ПРОЧИТАННЫХ 
    function markAllAsRead() {
        const btn = document.getElementById('markAllReadBtn');
        const originalText = btn.textContent;
        btn.textContent = '⏳ Обновление...';
        btn.disabled = true;

        fetch(`/dashboard/notifications/read-all/0`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.querySelectorAll('.notification-item.unread').forEach(item => {
                        item.classList.remove('unread');
                        item.dataset.read = 'true';
                        const badge = item.querySelector('.badge');
                        if (badge) badge.remove();
                        const markBtn = item.querySelector('.mark-read');
                        if (markBtn) markBtn.remove();
                    });
                    updateCounters();
                    
                    btn.textContent = '✅ Все прочитаны';
                    setTimeout(() => {
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }, 2000);
                } else {
                    btn.textContent = originalText;
                    btn.disabled = false;
                    showToast('Ошибка при отметке', 'error');
                }
            })
            .catch(err => {
                btn.textContent = originalText;
                btn.disabled = false;
                console.error('Error:', err);
                showToast('Ошибка при отметке', 'error');
            });
    }

    //  ПЕРЕХОД ПО УВЕДОМЛЕНИЮ 
    function goToNotification(id, url) {
        // Сначала отмечаем как прочитанное
        fetch(`/dashboard/notifications/read/${id}`, { method: 'POST' })
            .then(() => {
                window.location.href = url;
            })
            .catch(() => {
                window.location.href = url;
            });
    }

    //  ОБНОВЛЕНИЕ СЧЕТЧИКОВ 
    function updateCounters() {
        const unreadItems = document.querySelectorAll('.notification-item[data-read="false"]');
        const unreadCount = unreadItems.length;

        // Обновляем бейдж в шапке
        const unreadBadge = document.getElementById('unreadCount');
        if (unreadBadge) {
            if (unreadCount > 0) {
                unreadBadge.textContent = `${unreadCount} непрочитанных`;
            } else {
                unreadBadge.textContent = 'Все прочитано ✨';
            }
        }

        // Обновляем кнопку "Отметить все"
        const markAllBtn = document.getElementById('markAllReadBtn');
        if (markAllBtn) {
            markAllBtn.disabled = unreadCount === 0;
        }

        // Обновляем фильтры
        document.querySelectorAll('.filter-btn').forEach(btn => {
            const filter = btn.dataset.filter;
            if (filter === 'unread') {
                const countSpan = btn.querySelector('.count-unread');
                if (countSpan) {
                    if (unreadCount > 0) {
                        countSpan.textContent = unreadCount;
                        countSpan.style.display = '';
                    } else {
                        countSpan.style.display = 'none';
                    }
                } else if (unreadCount > 0) {
                    btn.innerHTML += ` <span class="count-unread">${unreadCount}</span>`;
                }
            }
        });

        // Обновляем счетчик в сайдбаре (глобальная функция из base.html.twig)
        if (typeof refreshNotificationCounter === 'function') {
            refreshNotificationCounter();
        }
    }

    //  ИНИЦИАЛИЗАЦИЯ 
    document.addEventListener('DOMContentLoaded', function() {
        // Обновляем счетчики при загрузке
        updateCounters();

        // Автообновление каждые 30 секунд
        setInterval(() => {
            // Проверяем новые уведомления
            fetch('/dashboard/notifications/unread-count-api', { method: 'GET' })
                .then(res => res.json())
                .then(data => {
                    // Если есть изменения, обновляем счетчики
                    const currentUnread = document.querySelectorAll('.notification-item[data-read="false"]').length;
                    if (currentUnread !== data.count) {
                        // Можно добавить логику для загрузки новых уведомлений
                    }
                })
                .catch(() => {});
        }, 30000);
    });
</script>
{% endblock %}